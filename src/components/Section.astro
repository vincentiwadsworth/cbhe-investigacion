---
/**
 * Section — Responsive section wrapper with background variant and max-width container.
 *
 * @prop bg              - Background color variant.
 * @prop maxWidth        - Max-width class for the inner container (default: "max-w-7xl").
 * @prop py              - Padding-Y responsive classes (default: "py-12 sm:py-16 md:py-24").
 * @prop id              - HTML id attribute.
 * @prop scrollMargin    - Add scroll-mt-24 for anchor navigation (default: false).
 *
 * @slot default         - Section content (placed inside the max-width container).
 */
export interface Props {
  bg?: "surface" | "surface-container-low" | "inverse-surface" | "primary-container";
  maxWidth?: string;
  py?: string;
  id?: string;
  scrollMargin?: boolean;
}

const {
  bg = "surface",
  maxWidth = "max-w-7xl",
  py = "py-12 sm:py-16 md:py-24",
  id,
  scrollMargin = false,
} = Astro.props;

const bgMap: Record<string, string> = {
  surface: "bg-surface",
  "surface-container-low": "bg-surface-container-low",
  "inverse-surface": "bg-inverse-surface",
  "primary-container": "bg-primary-container",
};
---

<section class:list={[bgMap[bg], py, scrollMargin && "scroll-mt-24"]} id={id}>
  <div class:list={[maxWidth, "mx-auto px-4 sm:px-6 md:px-8"]}>
    <slot />
  </div>
</section>