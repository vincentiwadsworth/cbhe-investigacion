---
/**
 * SubpageHero — Brand-coloured hero banner for subpages.
 *
 * DESIGN RULE: Zero gradients. Uses solid background colours only.
 * When bgImage is provided, the image is rendered at low opacity (default 0.12)
 * as a subtle texture overlay — no gradient overlays.
 *
 * @prop label           - Uppercase label above the title (e.g. "Institucional"). Omit to hide.
 * @prop title           - Main heading (h1). Required.
 * @prop subtitle        - Descriptive paragraph under the title. Omit to hide.
 * @prop bgImage         - Background image path (rendered at bgImageOpacity). Omit for solid colour.
 * @prop bgImageOpacity  - Opacity for the background image overlay (default: "0.12").
 * @prop variant         - "primary" (bg-primary, light text) or "dark" (bg-inverse-surface, inverse text).
 * @prop pt              - Padding-top responsive classes. Default varies by variant.
 * @prop pb              - Padding-bottom responsive classes. Default varies by variant.
 * @prop titleMaxW       - Max-width class for the h1 (default: "max-w-2xl").
 * @prop subtitleMaxW    - Max-width class for the subtitle (default: "max-w-2xl").
 * @prop subtitleSize    - Subtitle text size: "default" or "large".
 *
 * @slot default         - Extra content rendered after the subtitle (CTAs, badges, etc.).
 */
export interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  bgImage?: string;
  bgImageOpacity?: string;
  variant?: "primary" | "dark";
  pt?: string;
  pb?: string;
  titleMaxW?: string;
  subtitleMaxW?: string;
  subtitleSize?: "default" | "large";
}

const {
  label,
  title,
  subtitle,
  bgImage,
  bgImageOpacity = "0.12",
  variant = "primary",
  pt,
  pb,
  titleMaxW = "max-w-2xl",
  subtitleMaxW = "max-w-2xl",
  subtitleSize = "default",
} = Astro.props;

const subtitleSizeClass = subtitleSize === "large"
  ? "text-lg sm:text-xl md:text-2xl"
  : "text-base sm:text-lg md:text-xl";

const styles = {
  primary: {
    bg: "bg-primary",
    labelColor: "text-primary-fixed-dim",
    titleColor: "text-on-primary",
    subtitleColor: "text-on-primary/90",
  },
  dark: {
    bg: "bg-inverse-surface",
    labelColor: "text-primary-fixed-dim",
    titleColor: "text-inverse-on-surface",
    subtitleColor: "text-inverse-on-surface/80",
  },
}[variant];

const ptClass = pt ?? "pt-16 sm:pt-20 md:pt-24";
const pbClass = pb ?? "pb-12 sm:pb-16 md:pb-20";
---

<section class:list={[styles.bg, "relative", ptClass, pbClass, "px-4 sm:px-6 md:px-8 overflow-hidden"]}>
  {bgImage && (
    <div class="absolute inset-0" style={`opacity: ${bgImageOpacity};`}>
      <img src={bgImage} alt="" class="w-full h-full object-cover" aria-hidden="true" />
    </div>
  )}
  <div class="max-w-7xl mx-auto relative z-10">
    {label && (
      <span class:list={["font-bold tracking-widest uppercase text-sm block", styles.labelColor]}>
        {label}
      </span>
    )}
    <h1 class:list={["text-3xl sm:text-4xl md:text-5xl font-headline font-extrabold leading-tight tracking-tight mt-4", titleMaxW, styles.titleColor]}>
      {title}
    </h1>
    {subtitle && (
      <p class:list={[subtitleSizeClass, "font-body leading-relaxed mt-4 md:mt-6", subtitleMaxW, styles.subtitleColor]}>
        {subtitle}
      </p>
    )}
    <slot />
  </div>
</section>