---
import Icon from "./Icon.astro";

export interface Props {
  /** Which page is currently active — determines the highlighted nav link */
  active?: "inicio" | "quienes-somos" | "capacitacion" | "novedades" | "contacto";
}

const { active } = Astro.props;

const links = [
  { href: "", label: "Inicio", key: "inicio" as const },
  { href: "quienes-somos", label: "Quiénes somos", key: "quienes-somos" as const },
  { href: "capacitacion", label: "Capacitación", key: "capacitacion" as const },
  { href: "novedades", label: "Novedades", key: "novedades" as const },
  { href: "contacto", label: "Contacto", key: "contacto" as const },
];

const linkClass = (isActive: boolean) =>
  isActive
    ? "text-primary border-b-2 border-primary pb-1"
    : "text-on-surface-variant hover:text-primary transition-colors";
---

<nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md shadow-sm">
  <div class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto">
    <!-- Logo -->
    <a href="" class="flex items-center shrink-0">
      <img
        src="logo-cbhe.png"
        alt="CBHE — Cámara Boliviana de Hidrocarburos y Energía"
        width="200"
        height="109"
        class="h-[55px] w-auto"
      />
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center space-x-8">
      {links.map((link) => (
        <a href={link.href} class={linkClass(active === link.key)}>
          {link.label}
        </a>
      ))}
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-4">
      <a
        href="#afiliacion"
        class="bg-primary-container text-on-primary rounded-sm px-4 py-2 font-semibold hover:opacity-90 transition-opacity text-sm md:text-base"
      >
        Afiliarse
      </a>

      <!-- Mobile menu: native <details> — zero JS, keyboard + screen reader accessible -->
      <details class="group md:hidden">
        <summary class="list-none cursor-pointer p-2 -mr-2 min-h-11 min-w-11 flex items-center justify-center">
          <span class="group-open:hidden" aria-label="Abrir menú de navegación">
            <Icon name="material-symbols:menu" class="size-6 text-on-surface-variant" />
          </span>
          <span class="hidden group-open:inline" aria-label="Cerrar menú de navegación">
            <Icon name="material-symbols:close" class="size-6 text-on-surface-variant" />
          </span>
        </summary>
        <div class="absolute left-0 right-0 top-full bg-surface border-t border-outline-variant/30 shadow-lg">
          <div class="flex flex-col px-8 py-4 space-y-4">
            {links.map((link) => (
              <a href={link.href} class={linkClass(active === link.key) + " text-base py-1"}>
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </details>
    </div>
  </div>
</nav>
