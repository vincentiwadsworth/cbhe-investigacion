---
import Icon from "./Icon.astro";

export interface Props {
  images: { src: string; alt: string }[];
  /** Label for screen readers. Default: "Galería de imágenes" */
  ariaLabel?: string;
}

const { images, ariaLabel = "Galería de imágenes" } = Astro.props;
const totalSlides = images.length;
---

<div
  data-carousel
  class="relative"
  aria-roledescription="carousel"
  aria-label={ariaLabel}
>
  <!--
    Static grid fallback — visible when JS is disabled.
    Shows all images in a responsive grid.
  -->
  <div class="carousel-grid grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
    {images.map((img) => (
      <div class="aspect-[4/3] overflow-hidden rounded-sm bg-surface-container-low shadow-sm">
        <img
          src={img.src}
          alt={img.alt}
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
    ))}
  </div>

  <!--
    Interactive carousel viewport — hidden until JS adds .js-loaded.
  -->
  <div class="carousel-viewport hidden relative overflow-hidden rounded-sm bg-surface-container-low shadow-sm">
    <div
      class="carousel-track flex transition-transform duration-500 ease-out will-change-transform"
      style="transform: translateX(0)"
    >
      {images.map((img, i) => (
        <div
          class="carousel-slide min-w-0 shrink-0 w-full aspect-[16/9] md:aspect-[16/9] relative"
          role="group"
          aria-roledescription="slide"
          aria-label={`Imagen ${i + 1} de ${totalSlides}`}
        >
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>

    <!-- Prev / Next buttons -->
    <button
      data-carousel-prev
      class="absolute left-2 md:left-3 top-1/2 -translate-y-1/2 z-10 w-9 h-9 md:w-11 md:h-11 rounded-full bg-surface-container-low/90 hover:bg-surface-container-low text-primary flex items-center justify-center cursor-pointer shadow-sm transition-all focus-visible:outline-2 focus-visible:outline-primary"
      aria-label="Imagen anterior"
    >
      <Icon name="material-symbols:arrow-back" class="size-5 md:size-6" decorative={true} />
    </button>
    <button
      data-carousel-next
      class="absolute right-2 md:right-3 top-1/2 -translate-y-1/2 z-10 w-9 h-9 md:w-11 md:h-11 rounded-full bg-surface-container-low/90 hover:bg-surface-container-low text-primary flex items-center justify-center cursor-pointer shadow-sm transition-all focus-visible:outline-2 focus-visible:outline-primary"
      aria-label="Imagen siguiente"
    >
      <Icon name="material-symbols:arrow-forward" class="size-5 md:size-6" decorative={true} />
    </button>
  </div>

  <!-- Dot indicators -->
  <div class="carousel-dots hidden justify-center gap-2 md:gap-3 mt-3 md:mt-4 flex-wrap" role="tablist" aria-label="Navegación de diapositivas">
    {images.map((_, i) => (
      <button
        role="tab"
        class="carousel-dot w-2.5 h-2.5 md:w-3 md:h-3 rounded-full transition-all cursor-pointer focus-visible:outline-2 focus-visible:outline-primary"
        aria-selected={i === 0 ? "true" : "false"}
        aria-label={`Ir a la imagen ${i + 1}`}
        data-index={i}
      ></button>
    ))}
  </div>

  <!-- Status text for screen readers (hidden) -->
  <div class="sr-only" aria-live="polite" data-carousel-status></div>
</div>

<style>
  /* --- JS toggle: grid ↔ carousel --- */

  /* Default: grid visible, viewport + dots hidden */
  .carousel-grid {
    display: grid;
  }

  .carousel-viewport {
    display: none;
  }

  .carousel-dots {
    display: none;
  }

  /* JS loaded: grid hidden, viewport block, dots flex */
  .js-loaded .carousel-grid {
    display: none;
  }

  .js-loaded .carousel-viewport {
    display: block;
  }

  .js-loaded .carousel-dots {
    display: flex;
  }

  /* --- Dot indicator states (via aria-selected) --- */

  .carousel-dot {
    background-color: var(--color-surface-container-highest);
    border: 1px solid var(--color-outline);
  }

  .carousel-dot[aria-selected="true"] {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    transform: scale(1.15);
  }

  /* --- Reduced motion: disable track transition --- */

  @media (prefers-reduced-motion: reduce) {
    .carousel-track {
      transition: none;
    }
  }
</style>

<script is:inline>
  class ImageCarousel {
    /**
     * @param {HTMLElement} container - The [data-carousel] element
     */
    constructor(container) {
      this.container = container;
      this.track = container.querySelector(".carousel-track");
      this.slides = [...container.querySelectorAll(".carousel-slide")];
      this.dots = [...container.querySelectorAll(".carousel-dot")];
      this.prevBtn = container.querySelector("[data-carousel-prev]");
      this.nextBtn = container.querySelector("[data-carousel-next]");
      this.statusEl = container.querySelector("[data-carousel-status]");
      this.currentIndex = 0;
      this.totalSlides = this.slides.length;
      this.autoRotateInterval = null;
      this.isPaused = false;

      // Respect OS motion preference
      this.reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      // Swipe state
      this._swipeStartX = 0;
      this._swipeDeltaX = 0;
      this._isSwiping = false;
    }

    init() {
      if (this.totalSlides < 2) return;

      // Swap from static grid to interactive carousel
      this.container.classList.add("js-loaded");
      this._setAriaHidden();
      this._bindEvents();
      this._updateStatus();

      if (!this.reducedMotion) {
        this._startAutoRotate();
      }
    }

    // ----- Navigation -----

    /**
     * Navigate to slide at `index`. Wraps around.
     * @param {number} index
     */
    goTo(index) {
      // Wrap around at boundaries
      this.currentIndex =
        ((index % this.totalSlides) + this.totalSlides) % this.totalSlides;

      // Translate track
      this.track.style.transform = `translateX(-${this.currentIndex * 100}%)`;

      // Update aria-hidden on slides
      this._setAriaHidden();

      // Update dot indicators
      this.dots.forEach((dot, i) => {
        const isActive = i === this.currentIndex;
        dot.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      // Update screen reader status
      this._updateStatus();
    }

    /** Go to previous slide */
    prev() {
      this.goTo(this.currentIndex - 1);
    }

    /** Go to next slide */
    next() {
      this.goTo(this.currentIndex + 1);
    }

    // ----- Auto-rotate -----

    _startAutoRotate() {
      this._stopAutoRotate();
      this.autoRotateInterval = setInterval(() => {
        if (!this.isPaused && !this.reducedMotion) {
          this.next();
        }
      }, 5000);
    }

    _stopAutoRotate() {
      if (this.autoRotateInterval) {
        clearInterval(this.autoRotateInterval);
        this.autoRotateInterval = null;
      }
    }

    pause() {
      this.isPaused = true;
    }

    resume() {
      this.isPaused = false;
    }

    // ----- Event binding -----

    _bindEvents() {
      // Prev / Next buttons
      this.prevBtn.addEventListener("click", () => this.prev());
      this.nextBtn.addEventListener("click", () => this.next());

      // Dot navigation
      this.dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          this.goTo(parseInt(dot.dataset.index, 10));
        });
      });

      // Keyboard navigation
      this.container.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft") {
          e.preventDefault();
          this.prev();
        } else if (e.key === "ArrowRight") {
          e.preventDefault();
          this.next();
        }
      });

      // Pause on hover
      this.container.addEventListener("mouseenter", () => this.pause());
      this.container.addEventListener("mouseleave", () => this.resume());

      // Pause on focus within, resume on blur
      this.container.addEventListener("focusin", () => this.pause());
      this.container.addEventListener("focusout", () => {
        // Only resume if focus left the entire container
        if (!this.container.contains(document.activeElement)) {
          this.resume();
        }
      });

      // Touch / pointer swipe
      this._setupSwipe();
    }

    _setupSwipe() {
      const onPointerDown = (e) => {
        this._swipeStartX = e.clientX;
        this._swipeDeltaX = 0;
        this._isSwiping = true;
        this.container.setPointerCapture(e.pointerId);
      };

      const onPointerMove = (e) => {
        if (!this._isSwiping) return;
        this._swipeDeltaX = e.clientX - this._swipeStartX;
      };

      const onPointerUp = () => {
        if (!this._isSwiping) return;
        this._isSwiping = false;

        const threshold = 50;
        if (Math.abs(this._swipeDeltaX) > threshold) {
          if (this._swipeDeltaX > 0) {
            this.prev(); // Swipe right → prev
          } else {
            this.next(); // Swipe left → next
          }
        }
      };

      this.container.addEventListener("pointerdown", onPointerDown);
      this.container.addEventListener("pointermove", onPointerMove);
      this.container.addEventListener("pointerup", onPointerUp);
      this.container.addEventListener("pointercancel", () => {
        this._isSwiping = false;
      });
    }

    // ----- Internal helpers -----

    /** Hide non-visible slides from screen readers */
    _setAriaHidden() {
      this.slides.forEach((slide, i) => {
        if (i !== this.currentIndex) {
          slide.setAttribute("aria-hidden", "true");
        } else {
          slide.removeAttribute("aria-hidden");
        }
      });
    }

    /** Update the screen reader status text */
    _updateStatus() {
      if (this.statusEl) {
        const slide = this.slides[this.currentIndex];
        const img = slide ? slide.querySelector("img") : null;
        const alt = img ? img.getAttribute("alt") : "";
        this.statusEl.textContent = `Imagen ${this.currentIndex + 1} de ${this.totalSlides}${alt ? ": " + alt : ""}`;
      }
    }
  }

  // Boot on DOMContentLoaded
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll("[data-carousel]").forEach((el) => {
      new ImageCarousel(el).init();
    });
  });
</script>
