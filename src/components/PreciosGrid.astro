---
interface Commodity {
  price: number;
  unit: string;
  label: string;
}

interface PricesData {
  updated: string;
  usd_bob: { buy: number; sell: number };
  commodities: {
    WTI: Commodity;
    BRENT: Commodity;
    HENRY_HUB: Commodity;
    TTF: Commodity;
  };
}

interface Props {
  data: PricesData;
}

const { data } = Astro.props;
const { commodities, usd_bob } = data;

const updatedDate = new Date(data.updated);
const fmtDate = new Intl.DateTimeFormat("es-BO", {
  day: "2-digit",
  month: "short",
  year: "numeric",
  hour: "2-digit",
  minute: "2-digit",
  timeZone: "UTC",
  timeZoneName: "short",
});

const fmtPrice = (p: number) => p.toFixed(2);

const items = [
  commodities.WTI,
  commodities.BRENT,
  commodities.HENRY_HUB,
  commodities.TTF,
];
---

<section class="py-8 sm:py-10 md:py-12 bg-[#01406c]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
    <div class="flex items-baseline justify-between gap-4 mb-6">
      <h2 class="text-white/50 font-headline text-xs uppercase tracking-[0.2em]">Indicadores del sector</h2>
      <p class="text-white/30 text-xs whitespace-nowrap">{fmtDate.format(updatedDate)}</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-x-6 gap-y-6 lg:divide-x lg:divide-white/15">
      {items.map((item) => (
        <div class="lg:pl-6 first:lg:pl-0">
          <p class="text-white/50 text-xs uppercase tracking-wide mb-1.5">{item.label}</p>
          <p class="text-white font-headline font-extrabold text-2xl sm:text-3xl tabular-nums tracking-tight">
            {fmtPrice(item.price)}
          </p>
          <p class="text-white/30 text-xs mt-1">{item.unit}</p>
        </div>
      ))}

      <div class="lg:pl-6">
        <p class="text-white/50 text-xs uppercase tracking-wide mb-1.5">USD/BOB BCB</p>
        <div class="space-y-1">
          <div>
            <p class="text-white font-headline font-extrabold text-lg sm:text-xl tabular-nums tracking-tight">
              {fmtPrice(usd_bob.buy)}
              <span class="text-white/30 text-xs font-normal ml-1.5">Compra</span>
            </p>
          </div>
          <div>
            <p class="text-white font-headline font-extrabold text-lg sm:text-xl tabular-nums tracking-tight">
              {fmtPrice(usd_bob.sell)}
              <span class="text-white/30 text-xs font-normal ml-1.5">Venta</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
