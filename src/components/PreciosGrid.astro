---
interface Commodity {
  price: number;
  unit: string;
  label: string;
}

interface PricesData {
  updated: string;
  usd_bob: { buy: number; sell: number };
  commodities: {
    WTI: Commodity;
    BRENT: Commodity;
    HENRY_HUB: Commodity;
    TTF: Commodity;
  };
}

interface Props {
  data: PricesData;
}

const { data } = Astro.props;
const { commodities, usd_bob } = data;

const updatedDate = new Date(data.updated);
const fmtDate = new Intl.DateTimeFormat("es-BO", {
  day: "2-digit",
  month: "2-digit",
  year: "2-digit",
  hour: "2-digit",
  minute: "2-digit",
  hour12: false,
  timeZone: "America/La_Paz",
});

const fmtPrice = (p: number) => p.toFixed(2);

const items = [
  commodities.WTI,
  commodities.BRENT,
  commodities.HENRY_HUB,
  commodities.TTF,
];
---

<section class="py-8 sm:py-10 md:py-12 bg-[#01406c]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
    <div class="divide-y divide-white/10 lg:divide-y-0 lg:grid lg:grid-cols-5 lg:divide-x lg:divide-white/15">
      {items.map((item) => (
        <div class="flex lg:flex-col items-center lg:items-start justify-between lg:justify-start py-3.5 lg:py-0 lg:px-6 first:lg:pl-0">
          <p class="text-white/50 text-xs uppercase tracking-wide">{item.label}</p>
          <div class="text-right lg:text-left">
            <p class="text-white font-headline font-extrabold text-lg sm:text-xl lg:text-2xl xl:text-3xl tabular-nums tracking-tight">
              {fmtPrice(item.price)}
            </p>
            <p class="text-white/30 text-[10px] lg:text-xs mt-0.5">{item.unit}</p>
          </div>
        </div>
      ))}

      <div class="flex lg:flex-col items-center lg:items-start justify-between lg:justify-start py-3.5 lg:py-0 lg:px-6">
        <p class="text-white/50 text-xs uppercase tracking-wide">USD/BOB BCB</p>
        <div class="text-right lg:text-left">
          <p class="text-white font-headline font-extrabold text-base sm:text-lg lg:text-xl xl:text-2xl tabular-nums tracking-tight">
            {fmtPrice(usd_bob.buy)}
            <span class="text-white/30 text-[10px] lg:text-xs font-normal mx-1">Compra</span>
          </p>
          <p class="text-white font-headline font-extrabold text-base sm:text-lg lg:text-xl xl:text-2xl tabular-nums tracking-tight">
            {fmtPrice(usd_bob.sell)}
            <span class="text-white/30 text-[10px] lg:text-xs font-normal mx-1">Venta</span>
          </p>
        </div>
      </div>
    </div>

    <p class="text-white/30 text-[10px] sm:text-xs text-right mt-6">
      Actualizado {fmtDate.format(updatedDate)}
    </p>
  </div>
</section>
