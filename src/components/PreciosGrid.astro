---
import Icon from "./Icon.astro";

interface Commodity {
  price: number;
  unit: string;
  label: string;
}

interface PricesData {
  updated: string;
  usd_bob: { buy: number; sell: number };
  commodities: {
    WTI: Commodity;
    BRENT: Commodity;
    HENRY_HUB: Commodity;
    TTF: Commodity;
  };
}

interface Props {
  data: PricesData;
}

const { data } = Astro.props;
const { commodities, usd_bob } = data;

const updatedDate = new Date(data.updated);
const fmtDate = new Intl.DateTimeFormat("es-BO", {
  day: "2-digit",
  month: "short",
  year: "numeric",
  hour: "2-digit",
  minute: "2-digit",
  timeZone: "UTC",
  timeZoneName: "short",
});

const commodityCards: { key: string; icon: string; price: number; unit: string; label: string }[] = [
  { key: "WTI", icon: "oil-barrel", ...commodities.WTI },
  { key: "BRENT", icon: "oil-barrel", ...commodities.BRENT },
  { key: "HENRY_HUB", icon: "local-fire-department", ...commodities.HENRY_HUB },
  { key: "TTF", icon: "euro", ...commodities.TTF },
];

const fmtPrice = (p: number) => p.toFixed(2);
---

<section class="py-12 sm:py-16 md:py-24 bg-surface-container-low">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
    <div class="mb-8 md:mb-12">
      <h2 class="text-primary font-headline text-2xl md:text-3xl font-bold mb-4">Datos del Sector</h2>
      <p class="text-on-surface-variant font-body text-base md:text-lg max-w-3xl">
        Información actualizada diariamente de los principales indicadores del mercado energético internacional y el tipo de cambio referencial del Banco Central de Bolivia.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
      {
        commodityCards.map((c) => (
          <article class="bg-surface rounded-sm p-6 border border-surface-container-highest/50">
            <div class="w-12 h-12 bg-surface-container-low rounded-sm flex items-center justify-center mb-6">
              <Icon name={`material-symbols:${c.icon}`} class="text-primary size-6" />
            </div>
            <h3 class="font-headline font-bold text-on-surface mb-1 text-sm uppercase tracking-wide">{c.label}</h3>
            <p class="text-primary font-headline font-extrabold text-2xl md:text-3xl mb-1">
              {fmtPrice(c.price)}
            </p>
            <p class="text-on-surface-variant text-xs">{c.unit}</p>
          </article>
        ))
      }

      <article class="bg-surface rounded-sm p-6 border border-surface-container-highest/50">
        <div class="w-12 h-12 bg-surface-container-low rounded-sm flex items-center justify-center mb-6">
          <Icon name="material-symbols:currency-exchange" class="text-primary size-6" />
        </div>
        <h3 class="font-headline font-bold text-on-surface mb-3 text-sm uppercase tracking-wide">USD/BOB BCB</h3>
        <div class="space-y-2">
          <div>
            <p class="text-on-surface-variant text-xs mb-0.5">Compra</p>
            <p class="text-primary font-headline font-extrabold text-lg">
              {fmtPrice(usd_bob.buy)}
            </p>
          </div>
          <div class="w-full h-px bg-surface-container-highest/50"></div>
          <div>
            <p class="text-on-surface-variant text-xs mb-0.5">Venta</p>
            <p class="text-primary font-headline font-extrabold text-lg">
              {fmtPrice(usd_bob.sell)}
            </p>
          </div>
        </div>
      </article>
    </div>

    <p class="text-xs text-on-surface-variant mt-6 text-right">
      Actualizado: {fmtDate.format(updatedDate)}
    </p>
  </div>
</section>
