---
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const historia = [
  {
    year: "1986",
    title: "El origen",
    desc: "Quince empresas del sector de hidrocarburos fundan la Cámara Nacional de Hidrocarburos en Santa Cruz de la Sierra. Dos años después obtiene su personería jurídica mediante Resolución Suprema N° 203117, consolidándose como institución legalmente reconocida por el Estado boliviano.",
  },
  {
    year: "1994",
    title: "Crecimiento",
    desc: "Se incorporan todas las compañías con actividad en las diferentes fases de la industria petrolera. Se aprueba la primera clasificación por grupos y la institución adopta el nombre de Cámara Boliviana de Hidrocarburos, reflejando su alcance nacional.",
  },
  {
    year: "2001",
    title: "Modernización",
    desc: "La Cámara reorganiza su estructura en cuatro grupos industriales para responder al crecimiento del sector y a las inversiones realizadas en el país. Se readecúa el Estatuto Orgánico a la nueva realidad energética boliviana.",
  },
  {
    year: "2003",
    title: "Excelencia",
    desc: "La CBHE se convierte en la primera institución del sector hidrocarburífero boliviano en implementar un sistema de gestión de calidad ISO 9001, marcando un estándar de excelencia en sus servicios a los afiliados y al público.",
  },
  {
    year: "2007",
    title: "Compromiso social",
    desc: "Nace Fundesoc, la Fundación Boliviana para el Desarrollo Social, como brazo de responsabilidad social empresarial de la CBHE. Ese mismo año se define la filosofía ACTUAR, los seis pilares que guían el accionar institucional hasta hoy.",
  },
  {
    year: "2010",
    title: "Consolidación",
    desc: "La Cámara Boliviana de Hidrocarburos incorpora el sector Energía a su denominación y misión, transformándose en la CBHE que conocemos. Hoy reúne a casi un centenar de empresas organizadas en cinco grupos que cubren toda la cadena de valor energética.",
  },
];

const actuar = [
  {
    letter: "A",
    icon: "groups",
    title: "Agrupar",
    desc: "Reunir activamente a las empresas de toda la cadena de valor del sector energético bajo una representación institucional sólida.",
  },
  {
    letter: "C",
    icon: "chat",
    title: "Comunicar",
    desc: "Difundir información técnica, económica y sectorial de forma transparente y efectiva a los diferentes públicos de interés.",
  },
  {
    letter: "T",
    icon: "school",
    title: "Tecnificar",
    desc: "Impulsar la formación continua, la capacitación especializada y la certificación del talento humano del sector.",
  },
  {
    letter: "U",
    icon: "gavel",
    title: "Unificar",
    desc: "Promover criterios comunes bajo principios comerciales y éticos que fortalezcan la industria y sus estándares.",
  },
  {
    letter: "A",
    icon: "security",
    title: "Alentar",
    desc: "Fomentar programas de salud, seguridad industrial, medioambiente y responsabilidad social empresarial.",
  },
  {
    letter: "R",
    icon: "fact-check",
    title: "Representar",
    desc: "Defender los intereses de la industria energética ante los ámbitos público, privado, nacional e internacional.",
  },
];
---

<Layout
  title="Quiénes Somos"
  description="Desde 1986, la Cámara Boliviana de Hidrocarburos y Energía representa a las empresas del sector energético boliviano. Conozca nuestra historia, misión y filosofía institucional."
>
  <Navbar active="quienes-somos" />

  <main id="main-content">
    <!-- Hero -->
    <section class="relative bg-linear-to-br from-primary to-primary-container pt-20 sm:pt-24 md:pt-28 pb-16 sm:pb-20 md:pb-24 px-4 sm:px-6 md:px-8 overflow-hidden">
      <div class="absolute inset-0 opacity-[0.12]">
        <img
          src="images/instalaciones/cbhe-exterior.webp"
          alt=""
          class="w-full h-full object-cover"
          aria-hidden="true"
        />
      </div>
      <div class="max-w-7xl mx-auto relative z-10">
        <span class="text-primary-fixed-dim font-bold tracking-widest uppercase text-sm">Institucional</span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-headline font-extrabold text-on-primary leading-tight tracking-tight mt-4 max-w-3xl">
          Representamos la fuerza impulsora del sector energético boliviano
        </h1>
        <p class="text-base sm:text-lg md:text-xl text-on-primary-container font-body leading-relaxed mt-4 md:mt-6 max-w-2xl">
          Desde 1986, la Cámara Boliviana de Hidrocarburos y Energía integra a las empresas que impulsan el desarrollo energético del país. Casi un centenar de afiliadas trabajan para garantizar un futuro sostenible para Bolivia.
        </p>
      </div>
    </section>

    <!-- Historia — stripe A -->
    <section class="py-12 sm:py-16 md:py-24 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <h2 class="text-primary font-headline text-2xl md:text-3xl font-bold mb-4">Nuestra historia</h2>
        <p class="text-on-surface-variant font-body text-base md:text-lg mb-10 md:mb-14 max-w-3xl">
          Cuatro décadas de evolución al servicio del sector energético boliviano. Desde una iniciativa de 15 empresas hasta la institución referente que es hoy.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          {historia.map((item) => (
            <article class="bg-surface-container-low rounded-lg p-6 md:p-8 border border-outline-variant/20 hover:border-primary/30 hover:shadow-md transition-all duration-300">
              <span class="text-primary font-headline font-extrabold text-3xl md:text-4xl">{item.year}</span>
              <h3 class="font-headline font-bold text-on-surface text-lg md:text-xl mt-3 mb-3">{item.title}</h3>
              <p class="text-on-surface-variant font-body text-sm md:text-base leading-relaxed">{item.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Misión y Visión — stripe B -->
    <section class="py-12 sm:py-16 md:py-24 bg-surface-container-low">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
          <div class="bg-surface p-8 md:p-12 rounded-lg hover:bg-surface-container-low transition-colors duration-300 border border-outline-variant/20 hover:border-primary/30 hover:shadow-md">
            <div class="w-14 h-14 bg-primary-container rounded-lg flex items-center justify-center mb-8">
              <Icon name="material-symbols:flag" class="text-on-primary-container size-7" />
            </div>
            <h2 class="text-2xl md:text-3xl font-headline font-bold text-on-surface mb-5">Nuestra misión</h2>
            <p class="font-body text-on-surface-variant leading-relaxed text-base md:text-lg">
              Promover el desarrollo eficiente, competitivo y sostenible del sector de hidrocarburos y energía en Bolivia. Representamos y defendemos los intereses de nuestros afiliados a través de la excelencia técnica, el diálogo constructivo y la proposición de políticas públicas basadas en el rigor científico y económico.
            </p>
          </div>

          <div class="bg-surface p-8 md:p-12 rounded-lg hover:bg-surface-container-low transition-colors duration-300 border border-outline-variant/20 hover:border-primary/30 hover:shadow-md">
            <div class="w-14 h-14 bg-primary-container rounded-lg flex items-center justify-center mb-8">
              <Icon name="material-symbols:visibility" class="text-on-primary-container size-7" />
            </div>
            <h2 class="text-2xl md:text-3xl font-headline font-bold text-on-surface mb-5">Nuestra visión</h2>
            <p class="font-body text-on-surface-variant leading-relaxed text-base md:text-lg">
              Ser el referente institucional indiscutible del sector energético boliviano a nivel nacional e internacional. Aspiramos a liderar la transición hacia una matriz energética moderna, consolidando a Bolivia como un actor clave mediante la innovación tecnológica y las mejores prácticas operativas globales.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Filosofía ACTUAR — stripe A -->
    <section class="py-12 sm:py-16 md:py-24 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <h2 class="text-primary font-headline text-2xl md:text-3xl font-bold mb-4">Nuestra filosofía: ACTUAR</h2>
        <p class="text-on-surface-variant font-body text-base md:text-lg mb-10 md:mb-14 max-w-3xl">
          Seis pilares que reflejan el accionar y el comportamiento de la institución en la dinámica de la industria energética. Cada letra representa un compromiso concreto con nuestros afiliados y con Bolivia.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
          {actuar.map((item) => (
            <div class="group bg-surface-container-low rounded-lg p-6 md:p-8 border border-outline-variant/20 hover:border-primary/30 hover:shadow-md transition-all duration-300">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-primary-container shrink-0 rounded-lg flex items-center justify-center">
                  <Icon name={`material-symbols:${item.icon}`} class="text-on-primary-container size-5" />
                </div>
                <div class="min-w-0">
                  <div class="flex items-baseline gap-2 mb-1">
                    <span class="text-primary font-headline font-extrabold text-xl">{item.letter}</span>
                    <h3 class="font-headline font-bold text-on-surface text-base md:text-lg">{item.title}</h3>
                  </div>
                  <p class="text-on-surface-variant font-body text-sm md:text-base leading-relaxed">{item.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Cierre CTA — stripe B -->
    <section class="py-12 sm:py-16 md:py-20 bg-surface-container-low">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 md:px-8 text-center">
        <h2 class="text-primary font-headline text-2xl md:text-3xl font-bold mb-4">Conozca a quienes representamos</h2>
        <p class="text-on-surface-variant font-body text-base md:text-lg mb-8 max-w-xl mx-auto">
          Casi un centenar de empresas organizadas en cinco grupos industriales. Explore el directorio completo de nuestras afiliadas.
        </p>
        <a
          href="afiliadas"
          class="inline-flex items-center gap-2 bg-primary text-on-primary rounded-md px-8 py-4 font-semibold hover:bg-primary/90 hover:shadow-md transition-all min-h-[44px]"
        >
          Ver empresas afiliadas
          <Icon name="material-symbols:arrow-forward" class="size-5" />
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
