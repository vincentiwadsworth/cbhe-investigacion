---
import { getCollection } from "astro:content";
import Icon from "../components/Icon.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CtaBanner from "../components/CtaBanner.astro";
import SubpageHero from "../components/SubpageHero.astro";
import PageLayout from "../layouts/PageLayout.astro";

const cursos = await getCollection("cursos", ({ data }) => !data.draft);

const MESES: Record<string, number> = { Ene:0, Feb:1, Mar:2, Abr:3, May:4, Jun:5, Jul:6, Ago:7, Sep:8, Oct:9, Nov:10, Dic:11 };
const parseFecha = (d: string) => {
  const limpio = d.replace(/^Inicia:\s*/i, "").trim();
  const [dia, mes, año] = limpio.split(" ");
  return new Date(+año, MESES[mes], +dia).getTime();
};
cursos.sort((a: any, b: any) => parseFecha(b.data.startDate) - parseFecha(a.data.startDate));

const modeIcons: Record<string, string> = {
  Virtual: "desktop-windows",
  Presencial: "apartment",
  Híbrido: "devices",
};
---

<PageLayout
  title="Capacitación"
  description="Capacitación y certificación — Desarrollamos el talento del sector energético a través de programas especializados."
  active="capacitacion"
>
  <!-- Hero: unique layout with badge + 2-column, not a SubpageHero -->
  <section class="relative pt-20 sm:pt-28 md:pt-32 pb-16 sm:pb-20 md:pb-24 px-4 sm:px-6 md:px-8 overflow-hidden">
    <div class="absolute inset-0 bg-primary opacity-[0.05]"></div>
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 items-center">
      <div class="space-y-6 md:space-y-8 z-10 relative">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-surface-container-high rounded-full">
          <Icon name="material-symbols:school" class="text-primary size-4" />
          <span class="text-xs font-semibold text-primary uppercase tracking-wider">
            Formación continua
          </span>
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-headline font-bold text-on-surface leading-tight tracking-tight">
          Capacitación y certificación
        </h1>
        <p class="text-base sm:text-lg md:text-xl text-on-surface-variant leading-relaxed max-w-xl">
          Desarrollamos el talento del sector energético a través de programas especializados
          y certificaciones con los más altos estándares de la industria.
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <a
            href={`${import.meta.env.BASE_URL}/capacitacion/#catalogo`}
            class="bg-primary text-on-primary px-8 py-4 rounded-md font-semibold hover:bg-primary/90 hover:shadow-md transition-all min-h-[44px] inline-flex items-center gap-2"
          >
            Explorar capacitaciones
            <Icon name="material-symbols:arrow-downward" class="size-4" />
          </a>
          <a
            href="https://wa.me/59178500177"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-surface-container-high text-primary px-8 py-4 rounded-md font-semibold hover:bg-surface-container hover:border-primary/30 transition-all min-h-[44px] inline-flex items-center gap-2"
          >
            <Icon name="material-symbols:chat" class="size-5" />
            Solicitar curso
          </a>
        </div>
      </div>

      <!-- Image + stats card -->
      <div class="relative z-10 hidden lg:block">
        <div class="aspect-4/3 rounded-xl overflow-hidden shadow-2xl relative">
          <img
            alt="Ingenieros en entrenamiento"
            class="w-full h-full object-cover"
            loading="lazy"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCQquKpn8AuYAgAKnfFf8gINHBoa-rSoEErpFGPBdjJ5o8Gj77vhDjZ9sKEczS9eSJEnWtkAPQRJwXcVw-eBBanXCOeW0vJWO7gjLpgkfNtNNQ4Qx-FRH6cki4VB1-29a8EfWw6BMYe1x6vNfymxWVyl1KSFAMZNgT8Im06aEblh1kq9w7SI0-I1T3BAbcOewp9wdANhWvcXE7I__jUwpLYXSiFoen6x8DNd1gnLsj3_TeWe0L_jeNsFs2ZiMLWFrSZlpJHETf0h-A"
          />
          <div class="absolute inset-0 bg-primary/80" style="mix-blend-mode: multiply;"></div>
        </div>
        <div class="absolute -bottom-8 -left-8 bg-surface p-6 rounded-lg shadow-xl border border-outline-variant/30 flex gap-8">
          <div>
            <div class="text-3xl font-bold text-primary">1.233</div>
            <div class="text-xs text-on-surface-variant font-medium mt-1 uppercase tracking-wider">Cursos desde 2014</div>
          </div>
          <div class="w-px bg-outline-variant/30"></div>
          <div>
            <div class="text-3xl font-bold text-primary">15.275</div>
            <div class="text-xs text-on-surface-variant font-medium mt-1 uppercase tracking-wider">PROFESIONALES CAPACITADOS</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Formación con respaldo internacional -->
  <Section bg="surface-container-low">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div class="space-y-6 lg:pr-8">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-container/10 rounded-full">
          <Icon name="material-symbols:verified" class="text-primary size-4" />
          <span class="text-xs font-semibold text-primary uppercase tracking-wider">
            Respaldo internacional
          </span>
        </div>
        <h2 class="text-2xl md:text-3xl lg:text-4xl font-headline font-bold text-on-surface leading-tight">
          Formación certificada por entidades de clase mundial
        </h2>
        <p class="text-base md:text-lg text-on-surface-variant leading-relaxed max-w-lg">
          Las instalaciones de la CBHE están diseñadas para impartir programas de capacitación
          que cumplen con los requisitos de las certificadoras más exigentes del sector energético.
        </p>
        <p class="text-base text-on-surface-variant leading-relaxed max-w-lg">
          Nuestros programas cuentan con el respaldo de entidades como NFPA, UL y FM Approvals,
          referentes internacionales en seguridad contra incendios, calidad eléctrica y protección
          de activos industriales.
        </p>
      </div>

      <!-- Carousel -->
      <div class="relative aspect-[16/9] rounded-lg overflow-hidden bg-surface-container-low shadow-sm">
        {[
          { src: "/cbhe-web/images/capacitacion/carousel-1.webp", alt: "Capacitación técnica CBHE — sesión de formación" },
          { src: "/cbhe-web/images/capacitacion/carousel-2.webp", alt: "Capacitación técnica CBHE — trabajo en equipo" },
          { src: "/cbhe-web/images/capacitacion/carousel-3.webp", alt: "Capacitación técnica CBHE — sesión práctica" },
        ].map((img, i) => (
          <img
            src={img.src}
            alt={img.alt}
            class="absolute inset-0 w-full h-full object-cover fade-slide"
            style={`animation-delay: ${i * 5}s`}
            loading={i === 0 ? "eager" : "lazy"}
          />
        ))}
      </div>
    </div>

    <!-- Certification bar -->
    <div class="mt-16 pt-12 border-t border-outline-variant/15">
      <p class="text-center text-xs font-semibold text-outline uppercase tracking-widest mb-8">
        Avaladas por
      </p>
      <div class="flex flex-wrap justify-center items-center gap-10 md:gap-14">
        <div class="flex items-center gap-3">
          <img
            src="/cbhe-web/images/capacitacion/logo-nfpa.webp"
            alt="NFPA — National Fire Protection Association"
            class="h-16 md:h-20 w-auto object-contain"
            loading="lazy"
          />
          <span class="text-xs text-on-surface-variant font-medium hidden sm:inline">NFPA</span>
        </div>
        <div class="flex items-center gap-3">
          <img
            src="/cbhe-web/images/capacitacion/logo-ul.webp"
            alt="UL — Underwriters Laboratories"
            class="h-16 md:h-20 w-auto object-contain"
            loading="lazy"
          />
          <span class="text-xs text-on-surface-variant font-medium hidden sm:inline">UL</span>
        </div>
        <div class="flex items-center gap-3">
          <img
            src="/cbhe-web/images/capacitacion/logo-fm.webp"
            alt="FM Approvals"
            class="h-16 md:h-20 w-auto object-contain"
            loading="lazy"
          />
          <span class="text-xs text-on-surface-variant font-medium hidden sm:inline">FM Approvals</span>
        </div>
      </div>
    </div>
  </Section>

  <style>
    @keyframes slideFade {
      0%, 28% { opacity: 1; }
      33%, 95% { opacity: 0; }
      100% { opacity: 1; }
    }
    .fade-slide {
      opacity: 0;
      animation: slideFade 15s infinite;
    }
    .fade-slide:nth-child(1) { animation-delay: 0s; }
    .fade-slide:nth-child(2) { animation-delay: 5s; }
    .fade-slide:nth-child(3) { animation-delay: 10s; }
    @media (prefers-reduced-motion: reduce) {
      .fade-slide {
        animation: none;
        opacity: 1;
        position: static;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .fade-slide ~ .fade-slide {
        position: absolute;
        clip: rect(0, 0, 0, 0);
      }
    }
  </style>

  <!-- Course Grid -->
  <Section id="catalogo" bg="surface" scrollMargin>
    <div class="mb-8 md:mb-12">
      <SectionHeading title="Próximas capacitaciones" description="Formación diseñada para los desafíos actuales del sector." />
    </div>

    <div id="cursos-grid" data-load-more="3" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {cursos.map((curso) => (
        <article data-load-more-item class="group bg-surface rounded-lg shadow-sm hover:shadow-md border border-outline-variant/15 transition-all duration-300 hover:border-primary/30 flex flex-col overflow-hidden">
          {curso.data.image ? (
            <div class="aspect-video relative overflow-hidden">
              <img
                alt={curso.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                src={curso.data.image}
              />
              <div class="absolute top-4 right-4 bg-surface px-3 py-1 rounded-full text-xs font-bold text-primary flex items-center gap-1 shadow-sm">
                <Icon name={`material-symbols:${modeIcons[curso.data.modality]}`} class="size-3.5" />
                {curso.data.modality}
              </div>
            </div>
          ) : (
            <div class="aspect-video relative overflow-hidden bg-primary-container flex items-center justify-center">
              <Icon name="material-symbols:school" class="size-16 text-primary opacity-30" />
              <div class="absolute top-4 right-4 bg-surface px-3 py-1 rounded-full text-xs font-bold text-primary flex items-center gap-1 shadow-sm">
                <Icon name={`material-symbols:${modeIcons[curso.data.modality]}`} class="size-3.5" />
                {curso.data.modality}
              </div>
            </div>
          )}
          <div class="p-6 flex flex-col flex-grow">
            <div class="text-xs font-semibold text-tertiary uppercase tracking-wider mb-2">
              {curso.data.category}
            </div>
            <h3 class="text-xl font-headline font-bold text-on-surface leading-tight mb-4">
              {curso.data.title}
            </h3>
            {curso.data.description && (
              <p class="text-sm text-on-surface-variant line-clamp-2 mb-4">{curso.data.description}</p>
            )}
            <div class="space-y-3 mt-auto pt-6 border-t border-surface-container-high">
              <div class="flex items-center gap-3 text-sm text-on-surface-variant">
                <Icon name="material-symbols:calendar-today" class="text-outline size-5" />
                <span>{curso.data.startDate}</span>
              </div>
              {curso.data.price && (
                <div class="flex items-center gap-3 text-sm text-on-surface-variant">
                  <Icon name="material-symbols:payments" class="text-outline size-5" />
                  <span>{curso.data.price}</span>
                </div>
              )}
            </div>
            <div class="mt-6 flex flex-col gap-2">
              {curso.data.canvaLink ? (
                <a
                  href={curso.data.canvaLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-full text-center bg-primary text-on-primary py-3 rounded-md font-semibold hover:bg-primary/90 hover:shadow-md transition-all min-h-[44px] text-sm inline-flex items-center justify-center gap-2"
                >
                  <Icon name="material-symbols:open-in-new" class="size-4" />
                  Ver más
                </a>
              ) : (
                <a
                  href={`capacitacion/${curso.id}`}
                  class="w-full text-center bg-surface-container-high text-primary py-3 rounded-md font-semibold hover:bg-surface-container hover:border-primary/30 transition-all text-sm"
                >
                  Ver detalles
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <div data-load-more-wrapper class="mt-12 text-center">
      <button data-load-more-btn class="bg-surface border border-outline-variant px-8 py-3 rounded-md font-medium text-on-surface hover:bg-surface-container-low hover:border-primary/30 transition-all min-h-[44px] inline-flex items-center gap-2">
        <span data-load-more-text>Cargar más</span>
        <Icon name="material-symbols:refresh" class="size-5" />
      </button>
    </div>
  </Section>

  <!-- CTA: Inscríbase ahora -->
  <section class="bg-inverse-surface py-16 sm:py-20 md:py-28 px-4 sm:px-6 md:px-8">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div class="space-y-6">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-inverse-on-surface/10 rounded-full">
            <Icon name="material-symbols:qr-code-2" class="text-primary-fixed size-4" />
            <span class="text-xs font-semibold text-primary-fixed uppercase tracking-wider">
              Inscríbase ahora
            </span>
          </div>
          <h2 class="text-2xl md:text-3xl lg:text-4xl font-headline font-bold text-inverse-on-surface leading-tight">
            Inscríbase ahora
          </h2>
          <p class="text-inverse-on-surface/80 leading-relaxed max-w-lg text-base md:text-lg">
            Escanee el código QR con su dispositivo móvil para acceder directamente al formulario de inscripción y a la información de contacto del área de Capacitación de la CBHE.
          </p>
          <div class="flex flex-wrap gap-4 pt-2">
            <a
              href="https://wa.me/59179891193"
              target="_blank"
              rel="noopener noreferrer"
              class="bg-primary-fixed text-primary px-7 py-3.5 rounded-md font-semibold hover:bg-primary-fixed/90 transition-all min-h-[44px] inline-flex items-center gap-2 text-sm"
            >
              <Icon name="material-symbols:chat" class="size-5" />
              Reservar su lugar
            </a>
            <a
              href="mailto:capacitacion@cbhe.org.bo"
              class="border border-inverse-on-surface/30 text-inverse-on-surface px-7 py-3.5 rounded-md font-semibold hover:bg-inverse-on-surface/10 transition-all min-h-[44px] inline-flex items-center gap-2 text-sm"
            >
              <Icon name="material-symbols:mail" class="size-5" />
              Consultar por email
            </a>
          </div>
        </div>
        <div class="flex justify-center lg:justify-end">
          <div class="bg-inverse-on-surface/10 backdrop-blur-sm p-6 sm:p-8 rounded-xl border border-inverse-on-surface/15 text-center">
            <img
              src="/cbhe-web/images/qr-capacitacion.png"
              alt="Código QR de Capacitación CBHE"
              class="w-44 h-44 sm:w-48 sm:h-48 rounded-lg mb-4 mx-auto"
              loading="lazy"
            />
            <p class="text-sm text-inverse-on-surface/80 font-medium">Código QR oficial de Capacitación CBHE</p>
            <p class="text-xs text-inverse-on-surface/50 mt-1">Escanee con su dispositivo móvil</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { initLoadMore } from "../scripts/load-more";
    initLoadMore();
  </script>
</PageLayout>