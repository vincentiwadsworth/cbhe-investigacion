---
import { getCollection } from "astro:content";
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ImageCarousel from "../components/ImageCarousel.astro";

const cursos = await getCollection("cursos", ({ data }) => !data.draft);

const MESES: Record<string, number> = { Ene:0, Feb:1, Mar:2, Abr:3, May:4, Jun:5, Jul:6, Ago:7, Sep:8, Oct:9, Nov:10, Dic:11 };
const parseFecha = (d: string) => {
  const limpio = d.replace(/^Inicia:\s*/i, "").trim();
  const [dia, mes, año] = limpio.split(" ");
  return new Date(+año, MESES[mes], +dia).getTime();
};
cursos.sort((a: any, b: any) => parseFecha(b.data.startDate) - parseFecha(a.data.startDate));

const modeIcons: Record<string, string> = {
  Virtual: "desktop-windows",
  Presencial: "apartment",
  Híbrido: "devices",
};


---

<Layout
  title="Capacitación"
  description="Capacitación y certificación — Desarrollamos el talento del sector energético a través de programas especializados."
>
  <Navbar active="capacitacion" />

  <main id="main-content">
    <!-- Hero -->
    <section class="relative pt-20 sm:pt-28 md:pt-32 pb-16 sm:pb-20 md:pb-24 px-4 sm:px-6 md:px-8 overflow-hidden">
      <div class="absolute inset-0 bg-linear-to-br from-primary to-primary-container opacity-5"></div>
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 items-center">
        <div class="space-y-6 md:space-y-8 z-10 relative">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-surface-container-high rounded-full">
            <Icon name="material-symbols:school" class="text-primary size-4" />
            <span class="text-xs font-semibold text-primary uppercase tracking-wider">
              Formación continua
            </span>
          </div>
          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-headline font-bold text-on-surface leading-tight tracking-tight">
            Capacitación y certificación
          </h1>
          <p class="text-base sm:text-lg md:text-xl text-on-surface-variant leading-relaxed max-w-xl">
            Desarrollamos el talento del sector energético a través de programas especializados
            y certificaciones con los más altos estándares de la industria.
          </p>
          <div class="flex flex-wrap gap-4 pt-4">
            <a
              href="#catalogo"
              class="bg-primary-container text-on-primary px-8 py-4 rounded-sm font-medium hover:opacity-90 transition-opacity inline-flex items-center gap-2"
            >
              Explorar Capacitaciones
              <Icon name="material-symbols:arrow-downward" class="size-4" />
            </a>
            <a
              href="https://wa.me/59178500177"
              target="_blank"
              rel="noopener noreferrer"
              class="bg-surface-container-high text-primary px-8 py-4 rounded-sm font-medium hover:bg-surface-variant transition-colors inline-flex items-center gap-2"
            >
              <Icon name="material-symbols:chat" class="size-5" />
              Solicitar curso
            </a>
          </div>
        </div>

        <!-- Image + stats card -->
        <div class="relative z-10 hidden lg:block">
          <div class="aspect-4/3 rounded-xl overflow-hidden shadow-2xl relative">
            <img
              alt="Ingenieros en entrenamiento"
              class="w-full h-full object-cover"
              loading="lazy"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCQquKpn8AuYAgAKnfFf8gINHBoa-rSoEErpFGPBdjJ5o8Gj77vhDjZ9sKEczS9eSJEnWtkAPQRJwXcVw-eBBanXCOeW0vJWO7gjLpgkfNtNNQ4Qx-FRH6cki4VB1-29a8EfWw6BMYe1x6vNfymxWVyl1KSFAMZNgT8Im06aEblh1kq9w7SI0-I1T3BAbcOewp9wdANhWvcXE7I__jUwpLYXSiFoen6x8DNd1gnLsj3_TeWe0L_jeNsFs2ZiMLWFrSZlpJHETf0h-A"
            />
            <div class="absolute inset-0 bg-linear-to-t from-primary/80 to-transparent" style="mix-blend-mode: multiply;"></div>
          </div>
          <div class="absolute -bottom-8 -left-8 bg-surface p-6 rounded-lg shadow-xl border border-outline-variant/15 flex gap-8">
            <div>
              <div class="text-3xl font-bold text-primary">+50</div>
              <div class="text-xs text-on-surface-variant font-medium mt-1 uppercase tracking-wider">Cursos Anuales</div>
            </div>
            <div class="w-px bg-outline-variant/30"></div>
            <div>
              <div class="text-3xl font-bold text-primary">+2K</div>
              <div class="text-xs text-on-surface-variant font-medium mt-1 uppercase tracking-wider">PROFESIONALES CAPACITADOS</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Formación y certificaciones -->
    <section class="py-16 sm:py-20 md:py-28 px-4 sm:px-6 md:px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Columna de texto -->
          <div class="space-y-6 lg:pr-8">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-container/10 rounded-full">
              <Icon name="material-symbols:verified" class="text-primary size-4" />
              <span class="text-xs font-semibold text-primary uppercase tracking-wider">
                Estándares internacionales
              </span>
            </div>
            <h2 class="text-2xl md:text-3xl lg:text-4xl font-headline font-bold text-on-surface leading-tight">
              Formación certificada por entidades de clase mundial
            </h2>
            <p class="text-base md:text-lg text-on-surface-variant leading-relaxed max-w-lg">
              Las instalaciones de la CBHE están diseñadas para impartir programas de capacitación
              que cumplen con los requisitos de las certificadoras más exigentes del sector energético.
              Esto le garantiza una formación alineada con los estándares que la industria demanda.
            </p>
            <p class="text-base text-on-surface-variant leading-relaxed max-w-lg">
              Nuestros programas cuentan con el respaldo de entidades como NFPA, UL y FM Approvals,
              referentes mundiales en seguridad contra incendios, calidad eléctrica y protección
              de activos industriales.
            </p>
            <div class="flex flex-wrap gap-3 pt-2">
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-surface rounded-full border border-outline-variant/20 text-xs font-medium text-on-surface-variant">
                <Icon name="material-symbols:local-fire-department" class="size-3.5 text-tertiary" />
                Seguridad contra incendios
              </span>
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-surface rounded-full border border-outline-variant/20 text-xs font-medium text-on-surface-variant">
                <Icon name="material-symbols:bolt" class="size-3.5 text-tertiary" />
                Normas eléctricas
              </span>
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-surface rounded-full border border-outline-variant/20 text-xs font-medium text-on-surface-variant">
                <Icon name="material-symbols:factory" class="size-3.5 text-tertiary" />
                Protección industrial
              </span>
            </div>
          </div>

          <!-- Columna de galería -->
          <div class="relative">
            <ImageCarousel
              ariaLabel="Galería de capacitación CBHE"
              images={[
                { src: "/cbhe-web/images/capacitacion/carousel-1.webp", alt: "Capacitación técnica CBHE — sesión de formación" },
                { src: "/cbhe-web/images/capacitacion/carousel-2.webp", alt: "Capacitación técnica CBHE — trabajo en equipo" },
                { src: "/cbhe-web/images/capacitacion/carousel-3.webp", alt: "Capacitación técnica CBHE — sesión práctica" },
              ]}
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Certificaciones -->
    <section class="py-16 sm:py-20 md:py-28 px-4 sm:px-6 md:px-8 bg-background border-t border-outline-variant/10">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12 md:mb-16">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-primary-container/10 rounded-full mb-4">
            <Icon name="material-symbols:verified" class="text-primary size-4" />
            <span class="text-xs font-semibold text-primary uppercase tracking-wider">
              Aval internacional
            </span>
          </div>
          <h2 class="text-2xl md:text-3xl font-headline font-bold text-on-surface mb-4">
            Entidades que respaldan nuestra formación
          </h2>
          <p class="text-on-surface-variant max-w-xl mx-auto leading-relaxed">
            Organismos internacionales que emiten y avalan las certificaciones
            ofrecidas en los programas de la CBHE.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 md:gap-12">
          {[
            {
              src: "/cbhe-web/images/capacitacion/logo-nfpa.webp",
              alt: "NFPA — National Fire Protection Association",
              name: "NFPA",
              fullName: "National Fire Protection Association",
              description: "Estándares globales en seguridad contra incendios y eléctrica.",
            },
            {
              src: "/cbhe-web/images/capacitacion/logo-ul.webp",
              alt: "UL — Underwriters Laboratories",
              name: "UL",
              fullName: "Underwriters Laboratories",
              description: "Referente en certificación de seguridad de productos y sistemas.",
            },
            {
              src: "/cbhe-web/images/capacitacion/logo-fm.webp",
              alt: "FM Approvals",
              name: "FM",
              fullName: "FM Approvals",
              description: "Certificación internacional en protección de activos y riesgos industriales.",
            },
          ].map((cert) => (
            <div class="flex flex-col items-center text-center group">
              <div class="w-full aspect-[3/1.5] flex items-center justify-center p-6 bg-surface-container-low rounded-lg border border-outline-variant/15 mb-4">
                <img
                  src={cert.src}
                  alt={cert.alt}
                  class="max-h-full max-w-full object-contain"
                  loading="lazy"
                />
              </div>
              <p class="text-sm font-bold text-on-surface">{cert.name}</p>
              <p class="text-xs text-on-surface-variant mt-0.5">{cert.fullName}</p>
              <p class="text-xs text-outline mt-2 max-w-[220px]">{cert.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Course Grid -->
    <section id="catalogo" class="scroll-mt-24 py-12 sm:py-16 md:py-24 px-4 sm:px-6 md:px-8 bg-background">
      <div class="max-w-7xl mx-auto">
        <div class="mb-8 md:mb-12">
          <h2 class="text-2xl md:text-3xl font-headline font-bold text-on-surface">Próximas capacitaciones</h2>
          <p class="text-on-surface-variant mt-2">Formación diseñada para los desafíos actuales del sector.</p>
        </div>

        <div id="cursos-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {cursos.map((curso, i) => (
            <article data-load-more-item class="group bg-surface rounded-lg shadow-sm hover:shadow-md border border-outline-variant/15 transition-all duration-300 hover:bg-surface-container-lowest flex flex-col overflow-hidden">
              {curso.data.image ? (
                <div class="aspect-video relative overflow-hidden">
                  <img
                    alt={curso.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    src={curso.data.image}
                  />
                  <div class="absolute top-4 right-4 bg-surface px-3 py-1 rounded-full text-xs font-bold text-primary flex items-center gap-1 shadow-sm">
                    <Icon name={`material-symbols:${modeIcons[curso.data.modality]}`} class="size-3.5" />
                    {curso.data.modality}
                  </div>
                </div>
              ) : (
                <div class="aspect-video relative overflow-hidden bg-primary-container flex items-center justify-center">
                  <Icon name="material-symbols:school" class="size-16 text-primary opacity-30" />
                  <div class="absolute top-4 right-4 bg-surface px-3 py-1 rounded-full text-xs font-bold text-primary flex items-center gap-1 shadow-sm">
                    <Icon name={`material-symbols:${modeIcons[curso.data.modality]}`} class="size-3.5" />
                    {curso.data.modality}
                  </div>
                </div>
              )}
              <div class="p-6 flex flex-col flex-grow">
                <div class="text-xs font-semibold text-tertiary uppercase tracking-wider mb-2">
                  {curso.data.category}
                </div>
                <h3 class="text-xl font-headline font-bold text-on-surface leading-tight mb-4">
                  {curso.data.title}
                </h3>
                {curso.data.description && (
                  <p class="text-sm text-on-surface-variant line-clamp-2 mb-4">{curso.data.description}</p>
                )}
                <div class="space-y-3 mt-auto pt-6 border-t border-surface-container-high">
                  <div class="flex items-center gap-3 text-sm text-on-surface-variant">
                    <Icon name="material-symbols:calendar-today" class="text-outline size-5" />
                    <span>{curso.data.startDate}</span>
                  </div>
                  {curso.data.price && (
                    <div class="flex items-center gap-3 text-sm text-on-surface-variant">
                      <Icon name="material-symbols:payments" class="text-outline size-5" />
                      <span>{curso.data.price}</span>
                    </div>
                  )}
                </div>
                <div class="mt-6 flex flex-col gap-2">
                  {curso.data.canvaLink ? (
                    <a
                      href={curso.data.canvaLink}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="w-full text-center bg-primary-container text-on-primary hover:opacity-90 py-3 rounded-sm font-medium transition-opacity text-sm inline-flex items-center justify-center gap-2"
                    >
                      <Icon name="material-symbols:open-in-new" class="size-4" />
                      Ver más
                    </a>
                  ) : (
                    <a
                      href={`capacitacion/${curso.id}`}
                      class="w-full text-center bg-surface-container-high text-primary hover:bg-primary hover:text-on-primary py-3 rounded-sm font-medium transition-colors text-sm"
                    >
                      Ver Detalles
                    </a>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>

        <div id="cursos-load-more-wrapper" class="mt-12 text-center">
          <button id="cursos-load-more-btn" class="bg-surface border border-outline-variant px-8 py-3 rounded-sm font-medium text-on-surface hover:bg-surface-container-low transition-colors inline-flex items-center gap-2">
            <span id="cursos-load-more-text">Cargar más</span>
            <Icon name="material-symbols:refresh" class="size-5" />
          </button>
        </div>
      </div>
    </section>

    <!-- QR de inscripción rápida -->
    <section class="py-16 sm:py-20 md:py-28 px-4 sm:px-6 md:px-8 bg-[#01406c]">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <div class="space-y-6">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 rounded-full">
              <Icon name="material-symbols:qr-code-2" class="text-primary-fixed size-4" />
              <span class="text-xs font-semibold text-primary-fixed uppercase tracking-wider">
                Inscripción rápida
              </span>
            </div>
            <h2 class="text-2xl md:text-3xl lg:text-4xl font-headline font-bold text-white leading-tight">
              Inscríbase de forma inmediata
            </h2>
            <p class="text-white/80 leading-relaxed max-w-lg text-base md:text-lg">
              Escanee el código QR con su dispositivo móvil para acceder directamente al formulario de inscripción y a la información de contacto del área de Capacitación de la CBHE.
            </p>
            <div class="flex flex-wrap gap-4 pt-2">
              <a
                href="https://wa.me/59179891193"
                target="_blank"
                rel="noopener noreferrer"
                class="bg-primary-fixed text-[#01406c] px-7 py-3.5 rounded-sm font-semibold hover:opacity-90 transition-opacity inline-flex items-center gap-2 text-sm"
              >
                <Icon name="material-symbols:chat" class="size-5" />
                Reserve su lugar
              </a>
              <a
                href="mailto:capacitacion@cbhe.org.bo"
                class="border border-white/30 text-white px-7 py-3.5 rounded-sm font-semibold hover:bg-white/10 transition-colors inline-flex items-center gap-2 text-sm"
              >
                <Icon name="material-symbols:mail" class="size-5" />
                Consultar por email
              </a>
            </div>
          </div>
          <div class="flex justify-center lg:justify-end">
            <div class="bg-white/10 backdrop-blur-sm p-6 sm:p-8 rounded-xl border border-white/15 text-center">
              <img
                src="/cbhe-web/images/qr-capacitacion.png"
                alt="Código QR de Capacitación CBHE"
                class="w-44 h-44 sm:w-48 sm:h-48 rounded-lg mb-4 mx-auto"
                loading="lazy"
              />
              <p class="text-sm text-white/80 font-medium">Código QR oficial de Capacitación CBHE</p>
              <p class="text-xs text-white/50 mt-1">Escanee con su dispositivo móvil</p>
            </div>
          </div>
        </div>
      </div>
    </section>


  </main>

  <Footer />

  <script>
    (function () {
      const BATCH = 3
      const grid = document.getElementById("cursos-grid")
      const btn = document.getElementById("cursos-load-more-btn")
      const label = document.getElementById("cursos-load-more-text")
      if (!grid || !btn) return

      const items = grid.querySelectorAll("[data-load-more-item]")
      if (items.length <= BATCH) {
        btn.parentElement!.remove()
        return
      }

      let shown = BATCH
      items.forEach((el, i) => {
        if (i >= BATCH) el.classList.add("hidden")
      })

      const updateLabel = () => {
        const left = items.length - shown
        if (label) label.textContent = `Cargar más (${left})`
      }
      updateLabel()

      btn.addEventListener("click", () => {
        const next = Math.min(shown + BATCH, items.length)
        for (let i = shown; i < next; i++) items[i].classList.remove("hidden")
        shown = next
        if (shown >= items.length) {
          btn.parentElement!.remove()
          return
        }
        updateLabel()
      })
    })()
  </script>
</Layout>
