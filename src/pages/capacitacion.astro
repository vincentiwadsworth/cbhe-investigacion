---
import { getCollection } from "astro:content";
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const cursos = await getCollection("cursos", ({ data }) => !data.draft);

const MESES: Record<string, number> = { Ene:0, Feb:1, Mar:2, Abr:3, May:4, Jun:5, Jul:6, Ago:7, Sep:8, Oct:9, Nov:10, Dic:11 };
const parseFecha = (d: string) => { const [dia, mes, año] = d.split(" "); return new Date(+año, MESES[mes], +dia).getTime(); };
const cursosPorFecha = (a: any, b: any) => parseFecha(b.data.startDate.replace("Inicia: ", "")) - parseFecha(a.data.startDate.replace("Inicia: ", ""));
cursos.sort(cursosPorFecha);

const modeIcons: Record<string, string> = {
  Virtual: "desktop-windows",
  Presencial: "apartment",
  Híbrido: "devices",
};


---

<Layout
  title="Capacitación"
  description="Capacitación y certificación — Desarrollamos el talento del sector energético a través de programas especializados."
>
  <Navbar active="capacitacion" />

  <main id="main-content">
    <!-- Hero -->
    <section class="relative pt-20 sm:pt-28 md:pt-32 pb-16 sm:pb-20 md:pb-24 px-4 sm:px-6 md:px-8 overflow-hidden">
      <div class="absolute inset-0 bg-linear-to-br from-primary to-primary-container opacity-5"></div>
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 items-center">
        <div class="space-y-6 md:space-y-8 z-10 relative">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-surface-container-high rounded-full">
            <Icon name="material-symbols:school" class="text-primary size-4" />
            <span class="text-xs font-semibold text-primary uppercase tracking-wider">
              Formación continua
            </span>
          </div>
          <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-headline font-bold text-on-surface leading-tight tracking-tight">
            Capacitación y certificación
          </h1>
          <p class="text-base sm:text-lg md:text-xl text-on-surface-variant leading-relaxed max-w-xl">
            Desarrollamos el talento del sector energético a través de programas especializados
            y certificaciones con los más altos estándares de la industria.
          </p>
          <div class="flex flex-wrap gap-4 pt-4">
            <a
              href="#catalogo"
              class="bg-primary-container text-on-primary px-8 py-4 rounded-sm font-medium hover:opacity-90 transition-opacity inline-flex items-center gap-2"
            >
              Explorar Capacitaciones
              <Icon name="material-symbols:arrow-downward" class="size-4" />
            </a>
            <a
              href="https://wa.me/59178500177"
              target="_blank"
              rel="noopener noreferrer"
              class="bg-surface-container-high text-primary px-8 py-4 rounded-sm font-medium hover:bg-surface-variant transition-colors inline-flex items-center gap-2"
            >
              <Icon name="material-symbols:chat" class="size-5" />
              Solicitar curso
            </a>
          </div>
        </div>

        <!-- Image + stats card -->
        <div class="relative z-10 hidden lg:block">
          <div class="aspect-4/3 rounded-xl overflow-hidden shadow-2xl relative">
            <img
              alt="Ingenieros en entrenamiento"
              class="w-full h-full object-cover"
              loading="lazy"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCQquKpn8AuYAgAKnfFf8gINHBoa-rSoEErpFGPBdjJ5o8Gj77vhDjZ9sKEczS9eSJEnWtkAPQRJwXcVw-eBBanXCOeW0vJWO7gjLpgkfNtNNQ4Qx-FRH6cki4VB1-29a8EfWw6BMYe1x6vNfymxWVyl1KSFAMZNgT8Im06aEblh1kq9w7SI0-I1T3BAbcOewp9wdANhWvcXE7I__jUwpLYXSiFoen6x8DNd1gnLsj3_TeWe0L_jeNsFs2ZiMLWFrSZlpJHETf0h-A"
            />
            <div class="absolute inset-0 bg-linear-to-t from-primary/80 to-transparent" style="mix-blend-mode: multiply;"></div>
          </div>
          <div class="absolute -bottom-8 -left-8 bg-surface p-6 rounded-lg shadow-xl border border-outline-variant/15 flex gap-8">
            <div>
              <div class="text-3xl font-bold text-primary">+50</div>
              <div class="text-xs text-on-surface-variant font-medium mt-1 uppercase tracking-wider">Cursos Anuales</div>
            </div>
            <div class="w-px bg-outline-variant/30"></div>
            <div>
              <div class="text-3xl font-bold text-primary">+2k</div>
              <div class="text-xs text-on-surface-variant font-medium mt-1 uppercase tracking-wider">Profesionales</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Filters -->
    <section id="catalogo" class="scroll-mt-24 py-8 md:py-12 bg-surface-container-low border-y border-outline-variant/15">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <div class="flex justify-center">
          <div class="flex gap-1.5 bg-surface p-1.5 rounded-full shadow-sm border border-outline-variant/10">
            <button class="whitespace-nowrap px-5 py-2.5 bg-primary-container text-on-primary rounded-full text-sm font-medium transition-colors">
              Todos
            </button>
            <button class="whitespace-nowrap px-5 py-2.5 text-on-surface-variant hover:bg-surface-container-high rounded-full text-sm font-medium transition-colors">
              Curso
            </button>
            <button class="whitespace-nowrap px-5 py-2.5 text-on-surface-variant hover:bg-surface-container-high rounded-full text-sm font-medium transition-colors">
              Certificación
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Course Grid -->
    <section class="py-12 sm:py-16 md:py-24 px-4 sm:px-6 md:px-8 bg-background">
      <div class="max-w-7xl mx-auto">
        <div class="mb-8 md:mb-12">
          <h2 class="text-2xl md:text-3xl font-headline font-bold text-on-surface">Próximas capacitaciones</h2>
          <p class="text-on-surface-variant mt-2">Formación diseñada para los desafíos actuales del sector.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {cursos.map((curso) => (
            <article class="group bg-surface rounded-lg shadow-sm hover:shadow-md border border-outline-variant/15 transition-all duration-300 hover:bg-surface-container-lowest flex flex-col overflow-hidden">
              <div class="aspect-video relative overflow-hidden">
                <img
                  alt={curso.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                  src={curso.data.image}
                />
                <div class="absolute top-4 right-4 bg-surface px-3 py-1 rounded-full text-xs font-bold text-primary flex items-center gap-1 shadow-sm">
                  <Icon name={`material-symbols:${modeIcons[curso.data.modality]}`} class="size-3.5" />
                  {curso.data.modality}
                </div>
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <div class="text-xs font-semibold text-tertiary uppercase tracking-wider mb-2">
                  {curso.data.category}
                </div>
                <h3 class="text-xl font-headline font-bold text-on-surface leading-tight mb-4">
                  {curso.data.title}
                </h3>
                <div class="space-y-3 mt-auto pt-6 border-t border-surface-container-high">
                  <div class="flex items-center gap-3 text-sm text-on-surface-variant">
                    <Icon name="material-symbols:calendar-today" class="text-outline size-5" />
                    <span>{curso.data.startDate}</span>
                  </div>
                  <div class="flex items-center gap-3 text-sm text-on-surface-variant">
                    <Icon name="material-symbols:schedule" class="text-outline size-5" />
                    <span>{curso.data.hours}</span>
                  </div>
                </div>
                <a
                  href={`capacitacion/${curso.id}`}
                  class="mt-6 w-full text-center bg-surface-container-high text-primary hover:bg-primary hover:text-on-primary py-3 rounded-sm font-medium transition-colors text-sm"
                >
                  Ver Detalles
                </a>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-12 text-center">
          <button class="bg-surface border border-outline-variant px-8 py-3 rounded-sm font-medium text-on-surface hover:bg-surface-container-low transition-colors inline-flex items-center gap-2">
            Cargar más
            <Icon name="material-symbols:refresh" class="size-5" />
          </button>
        </div>
      </div>
    </section>



    <!-- Alianzas -->
    <section class="py-12 sm:py-16 md:py-24 px-4 sm:px-6 md:px-8 bg-background border-t border-outline-variant/15">
      <div class="max-w-7xl mx-auto text-center">
        <h2 class="text-sm font-semibold text-outline uppercase tracking-widest mb-12">
          Alianzas académicas y tecnológicas
        </h2>
        <div class="flex flex-wrap justify-center items-center gap-12 opacity-60 hover:opacity-100 transition-all duration-500">
          {[
            { icon: "account-balance", label: "Universidad X" },
            { icon: "science", label: "Aqualitos" },
            { icon: "language", label: "ICC" },
            { icon: "architecture", label: "Estudio X" },
          ].map((ally) => (
            <div class="flex items-center gap-2 font-bold text-xl text-on-surface">
              <Icon name={`material-symbols:${ally.icon}`} class="size-8" />
              {ally.label}
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
