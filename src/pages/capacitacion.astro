---
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Capacitación"
  description="Capacitación y certificación — Desarrollando el talento del sector energético a través de programas especializados."
>
  <Navbar active="capacitacion" />

  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-24 px-8 overflow-hidden">
      <div class="absolute inset-0 bg-linear-to-br from-primary to-primary-container opacity-5"></div>
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-8 z-10 relative">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-surface-container-high rounded-full">
            <Icon name="material-symbols:school" class="text-primary size-4" />
            <span class="text-xs font-semibold text-primary uppercase tracking-wider">
              Formación Continua
            </span>
          </div>
          <h1 class="text-5xl md:text-6xl font-headline font-bold text-on-surface leading-tight tracking-tight">
            Capacitación y certificación
          </h1>
          <p class="text-lg md:text-xl text-on-surface-variant leading-relaxed max-w-xl">
            Desarrollando el talento del sector energético a través de programas especializados
            y certificaciones con los más altos estándares de la industria.
          </p>
          <div class="flex flex-wrap gap-4 pt-4">
            <a
              href="#catalogo"
              class="bg-primary-container text-on-primary px-8 py-4 rounded-sm font-medium hover:opacity-90 transition-opacity inline-flex items-center gap-2"
            >
              Explorar Cursos
              <Icon name="material-symbols:arrow-downward" class="size-4" />
            </a>
            <a
              href="#certificaciones"
              class="bg-surface-container-high text-primary px-8 py-4 rounded-sm font-medium hover:bg-surface-variant transition-colors"
            >
              Ver Certificaciones
            </a>
          </div>
        </div>

        <!-- Image + stats card -->
        <div class="relative z-10 hidden lg:block">
          <div class="aspect-4/3 rounded-xl overflow-hidden shadow-2xl relative">
            <img
              alt="Ingenieros en entrenamiento"
              class="w-full h-full object-cover"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuCQquKpn8AuYAgAKnfFf8gINHBoa-rSoEErpFGPBdjJ5o8Gj77vhDjZ9sKEczS9eSJEnWtkAPQRJwXcVw-eBBanXCOeW0vJWO7gjLpgkfNtNNQ4Qx-FRH6cki4VB1-29a8EfWw6BMYe1x6vNfymxWVyl1KSFAMZNgT8Im06aEblh1kq9w7SI0-I1T3BAbcOewp9wdANhWvcXE7I__jUwpLYXSiFoen6x8DNd1gnLsj3_TeWe0L_jeNsFs2ZiMLWFrSZlpJHETf0h-A"
            />
            <div class="absolute inset-0 bg-linear-to-t from-primary/80 to-transparent" style="mix-blend-mode: multiply;"></div>
          </div>
          <div class="absolute -bottom-8 -left-8 bg-surface p-6 rounded-lg shadow-xl border border-outline-variant/15 flex gap-8">
            <div>
              <div class="text-3xl font-bold text-primary">+50</div>
              <div class="text-xs text-on-surface-variant font-medium mt-1 uppercase tracking-wider">Cursos Anuales</div>
            </div>
            <div class="w-px bg-outline-variant/30"></div>
            <div>
              <div class="text-3xl font-bold text-primary">+2k</div>
              <div class="text-xs text-on-surface-variant font-medium mt-1 uppercase tracking-wider">Profesionales</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Filters -->
    <section id="catalogo" class="py-12 bg-surface-container-low border-y border-outline-variant/15">
      <div class="max-w-7xl mx-auto px-8">
        <div class="flex flex-col md:flex-row gap-6 justify-between items-center bg-surface p-4 rounded-lg shadow-sm border border-outline-variant/10">
          <div class="relative w-full md:w-96">
            <Icon name="material-symbols:search" class="absolute left-4 top-1/2 -translate-y-1/2 text-outline size-5" />
            <input
              type="text"
              placeholder="Buscar programas, instructores..."
              class="w-full bg-surface-container-low border-none rounded-sm py-3 pl-12 pr-4 text-on-surface focus:ring-2 focus:ring-primary focus:bg-surface transition-all placeholder:text-outline"
            />
          </div>
          <div class="flex gap-2 w-full md:w-auto overflow-x-auto pb-2 md:pb-0">
            <button class="whitespace-nowrap px-4 py-2 bg-primary-container text-on-primary rounded-full text-sm font-medium transition-colors">
              Todos
            </button>
            {
              ["Técnico", "Ambiental", "Legal", "Tecnológico"].map((cat) => (
                <button class="whitespace-nowrap px-4 py-2 bg-surface-container-high text-on-surface-variant hover:bg-surface-variant rounded-full text-sm font-medium transition-colors">
                  {cat}
                </button>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Course Grid -->
    <section class="py-24 px-8 bg-background">
      <div class="max-w-7xl mx-auto">
        <div class="mb-12">
          <h2 class="text-3xl font-headline font-bold text-on-surface">Próximos cursos</h2>
          <p class="text-on-surface-variant mt-2">Capacitación diseñada para los desafíos actuales del sector.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {
            [
              {
                category: "Técnico",
                title: "Gestión Integral de Yacimientos No Convencionales",
                mode: "Virtual",
                modeIcon: "desktop-windows",
                img: "https://lh3.googleusercontent.com/aida-public/AB6AXuC4_pjLAryBS3iEif_hYdf5__NDV2PlXOBxiXac2XtzJprSmak1oGIbL8Ti9FvarB9IAFEYogddzjS_Z6v_-NJUs407_IJ9R_XUzrNDS3GHzupKVD2r2Qi8I_VnmfNCK59IC5qByrgsr79vhZ5g31b5iaruc2lB6D1CcgC2FKnIL0dpuDobNOJUGEV3kkhpUDM3KmKvEtco_CYXn7KtV3btZTNfyfAgFw5ehaeQqwhcNqp7UGLxI5znysTM8EAalJmxXE-3jN5YuEM",
                date: "Inicia: 15 Oct 2024",
                hours: "40 horas académicas"
              },
              {
                category: "Legal",
                title: "Marco Normativo Ambiental para Proyectos Energéticos",
                mode: "Presencial",
                modeIcon: "apartment",
                img: "https://lh3.googleusercontent.com/aida-public/AB6AXuDwBAasDz3rbmNdKbhTfOsT-2hRkEjwg3Bx79-kAZdEWp4y_d1jmuYzOUGJscsfYd3PkS7kc1PVb_12leAUSDUisZkz2I2trV7PV6lzHSIE8lCCpVmk1PDlSxfbaKhbK9pyP_wnLe4k3NPTd86-W-7zO_3q_S5vO1kNHV0AwMW3nM0Jxq7-jjKNz39wS_B25n03isHI05lLN1wxGOKZVzV6Uic1mTTwAe0G72RmFcqrSMdLI1fZSYNWmxtnrR-KNlPv_O5TfbYodks",
                date: "Inicia: 02 Nov 2024",
                hours: "24 horas académicas"
              },
              {
                category: "Tecnológico",
                title: "Análisis de Datos Aplicado a la Optimización de Perforación",
                mode: "Híbrido",
                modeIcon: "devices",
                img: "https://lh3.googleusercontent.com/aida-public/AB6AXuDse6i3lenLfmQh0m5I8Ica8fWF6oDTgMI3kmITpiGgZskKn9cNrvz_gq0nG47GexKiDP5TS4gB50D8_7C9BqM02Ss7N6TNcGRn_noM074kCcRN27TitU8uB8eFZ3gWXWq55QbwStLSzmIXiUe76BKoFs-GEkmDAehXuw2d51XFycKxbywVmYFUWePWmoQsBkOL9diPVnBbV3h34zF8tY5dPdMiQMvRWUhV7pE8E8_G22mcb-KxYwLGpNCt2brzJeAhx7DWZRhenYM",
                date: "Inicia: 20 Nov 2024",
                hours: "60 horas académicas"
              }
            ].map((course) => (
              <article class="group bg-surface rounded-lg shadow-sm hover:shadow-md border border-outline-variant/15 transition-all duration-300 hover:bg-surface-container-lowest flex flex-col overflow-hidden">
                <div class="aspect-video relative overflow-hidden">
                  <img
                    alt={course.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    src={course.img}
                  />
                  <div class="absolute top-4 right-4 bg-surface px-3 py-1 rounded-full text-xs font-bold text-primary flex items-center gap-1 shadow-sm">
                    <Icon name={`material-symbols:${course.modeIcon}`} class="size-3.5" />
                    {course.mode}
                  </div>
                </div>
                <div class="p-6 flex flex-col flex-grow">
                  <div class="text-xs font-semibold text-tertiary uppercase tracking-wider mb-2">
                    {course.category}
                  </div>
                  <h3 class="text-xl font-headline font-bold text-on-surface leading-tight mb-4">
                    {course.title}
                  </h3>
                  <div class="space-y-3 mt-auto pt-6 border-t border-surface-container-high">
                    <div class="flex items-center gap-3 text-sm text-on-surface-variant">
                      <Icon name="material-symbols:calendar-today" class="text-outline size-5" />
                      <span>{course.date}</span>
                    </div>
                    <div class="flex items-center gap-3 text-sm text-on-surface-variant">
                      <Icon name="material-symbols:schedule" class="text-outline size-5" />
                      <span>{course.hours}</span>
                    </div>
                  </div>
                  <a
                    href="#"
                    class="mt-6 w-full text-center bg-surface-container-high text-primary hover:bg-primary hover:text-on-primary py-3 rounded-sm font-medium transition-colors text-sm"
                  >
                    Ver Detalles
                  </a>
                </div>
              </article>
            ))
          }
        </div>

        <div class="mt-12 text-center">
          <button class="bg-surface border border-outline-variant px-8 py-3 rounded-sm font-medium text-on-surface hover:bg-surface-container-low transition-colors inline-flex items-center gap-2">
            Cargar más cursos
            <Icon name="material-symbols:refresh" class="size-5" />
          </button>
        </div>
      </div>
    </section>

    <!-- Certifications -->
    <section id="certificaciones" class="py-24 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
          <div class="lg:col-span-4 space-y-6">
            <h2 class="text-3xl font-headline font-bold text-on-surface">Certificaciones Técnicas</h2>
            <p class="text-on-surface-variant leading-relaxed">
              Validamos la competencia y experiencia técnica mediante estándares rigurosos
              reconocidos por la industria energética nacional e internacional.
            </p>
            <a
              href="#"
              class="inline-flex items-center gap-2 text-primary font-medium hover:underline underline-offset-4"
            >
              Conoce el proceso de certificación
              <Icon name="material-symbols:arrow-forward" class="size-5" />
            </a>
          </div>

          <div class="lg:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-6">
            {
              [
                {
                  icon: "verified",
                  title: "Operador de Planta",
                  desc: "Certificación Nivel I y II para operadores de plantas de procesamiento de gas y refinerías.",
                  tag: "Norma ISO 9001"
                },
                {
                  icon: "security",
                  title: "HSE en Campo",
                  desc: "Acreditación en Salud, Seguridad y Medio Ambiente para operaciones de perforación e intervención.",
                  tag: "Estándar OGP"
                }
              ].map((cert) => (
                <div class="bg-surface p-8 rounded-xl border border-outline-variant/15 shadow-sm hover:shadow-md transition-shadow">
                  <Icon name={`material-symbols:${cert.icon}`} class="text-tertiary size-10 mb-4" />
                  <h3 class="text-lg font-bold text-on-surface mb-2">{cert.title}</h3>
                  <p class="text-sm text-on-surface-variant mb-6">{cert.desc}</p>
                  <span class="text-xs font-semibold bg-surface-container-high text-on-surface-variant px-3 py-1 rounded-full uppercase tracking-wider">
                    {cert.tag}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Alianzas -->
    <section class="py-24 px-8 bg-background border-t border-outline-variant/15">
      <div class="max-w-7xl mx-auto text-center">
        <h2 class="text-sm font-semibold text-outline uppercase tracking-widest mb-12">
          Alianzas Académicas y Tecnológicas
        </h2>
        <div class="flex flex-wrap justify-center items-center gap-12 opacity-60 hover:opacity-100 transition-all duration-500">
          {
            [
              { icon: "account-balance", label: "Universidad X" },
              { icon: "science", label: "Aqualitos" },
              { icon: "language", label: "ICC" },
              { icon: "architecture", label: "Estudio X" }
            ].map((ally) => (
              <div class="flex items-center gap-2 font-bold text-xl text-on-surface">
                <Icon name={`material-symbols:${ally.icon}`} class="size-8" />
                {ally.label}
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
