---
import { getCollection } from "astro:content";
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const articulos = await getCollection("articulos", ({ data }) => !data.draft);

const MESES: Record<string, number> = { Ene:0, Feb:1, Mar:2, Abr:3, May:4, Jun:5, Jul:6, Ago:7, Sep:8, Oct:9, Nov:10, Dic:11 };
const porFechaDesc = (a: { data: { date: string } }, b: { data: { date: string } }) => {
  const [da, ma, aa] = a.data.date.split(" ");
  const [db, mb, ab] = b.data.date.split(" ");
  return new Date(+ab, MESES[mb], +db).getTime() - new Date(+aa, MESES[ma], +da).getTime();
};
const ordenados = articulos.sort(porFechaDesc);

const featured = ordenados.find((a) => a.data.featured);
const grid = ordenados.filter((a) => !a.data.featured);
---

<Layout
  title="Novedades"
  description="Novedades y publicaciones — Un espacio para las noticias, eventos y análisis del sector energético boliviano."
>
  <Navbar active="novedades" />

  <!-- Hero -->
  <section class="relative bg-linear-to-br from-primary to-primary-container pt-20 sm:pt-24 md:pt-28 pb-24 sm:pb-28 md:pb-32 px-4 sm:px-6 md:px-8 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.12]">
      <img
        src="images/instalaciones/cbhe-auditorio.jpg"
        alt=""
        class="w-full h-full object-cover"
        aria-hidden="true"
      />
    </div>
    <div class="max-w-7xl mx-auto relative z-10">
      <span class="text-primary-fixed-dim font-bold tracking-widest uppercase text-sm">Novedades</span>
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-headline font-extrabold text-on-primary leading-tight tracking-tight mt-4 max-w-3xl">
        Novedades y publicaciones
      </h1>
      <p class="text-base sm:text-lg md:text-xl text-on-primary-container font-body leading-relaxed mt-4 md:mt-6 max-w-2xl">
        Un espacio para las noticias, eventos y análisis del sector energético boliviano.
      </p>
    </div>
  </section>

  <main id="main-content" class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 pb-16 sm:pb-20 md:pb-24">
    <!-- Contenido Principal -->
    <div class="space-y-12">
      {
        featured && (
          <!-- Noticia Destacada -->
          <article class="bg-surface-container-low rounded-lg overflow-hidden flex flex-col md:flex-row group transition-all duration-300 hover:bg-surface-container-highest">
            {featured.data.image && (
              <div class="md:w-1/2 min-h-[300px] bg-cover bg-center" style={`background-image: url('${featured.data.image}')`}></div>
            )}
            <div class="p-8 md:w-1/2 flex flex-col justify-center">
              <span class="text-xs font-semibold text-primary uppercase tracking-wider font-label mb-4">
                {featured.data.category}
              </span>
              <h2 class="text-3xl leading-snug font-bold text-on-surface mb-4 font-headline group-hover:text-primary transition-colors">
                {featured.data.title}
              </h2>
              <p class="text-base text-on-surface-variant leading-relaxed font-body mb-6">
                {featured.data.excerpt}
              </p>
              <div class="mt-auto flex items-center justify-between text-sm text-on-surface-variant">
                <span class="flex items-center gap-2">
                  <Icon name="material-symbols:calendar-today" class="size-4" />
                  {featured.data.date}
                </span>
                <a href={`novedades/${featured.id}`} class="text-primary font-medium hover:underline inline-flex items-center gap-1">
                  Leer más
                  <Icon name="material-symbols:arrow-forward" class="size-4" />
                </a>
              </div>
            </div>
          </article>
        )
      }

      <!-- Grid de Noticias -->
      <div id="novedades-grid" class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {grid.map((articulo) => (
          <article data-load-more-item class="bg-surface-container-low p-6 rounded-lg transition-all duration-300 hover:bg-surface-container-highest flex flex-col">
            {articulo.data.image && (
              <div
                class="h-48 rounded bg-cover bg-center mb-6"
                style={`background-image: url('${articulo.data.image}')`}
              ></div>
            )}
            <span class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider font-label mb-3">
              {articulo.data.category}
            </span>
            <h3 class="text-xl font-semibold text-on-surface mb-3 font-headline leading-snug">
              {articulo.data.title}
            </h3>
            <p class="text-base text-on-surface-variant leading-relaxed font-body flex-grow">
              {articulo.data.excerpt}
            </p>
            <div class="mt-6 flex items-center justify-between text-sm text-on-surface-variant border-t border-outline-variant/15 pt-4">
              <span>{articulo.data.date}</span>
            </div>
          </article>
        ))}
      </div>

      <div id="novedades-load-more-wrapper" class="text-center pt-8">
        <button id="novedades-load-more-btn" class="bg-surface-container-high text-primary px-6 py-3 rounded-sm text-sm font-medium hover:bg-surface-variant transition-colors font-headline inline-flex items-center gap-2">
          <span id="novedades-load-more-text">Cargar más noticias</span>
          <Icon name="material-symbols:expand-more" class="size-4" />
        </button>
      </div>
    </div>

  </main>

  <Footer />

  <script>
    (function () {
      const BATCH = 4
      const grid = document.getElementById("novedades-grid")
      const btn = document.getElementById("novedades-load-more-btn")
      const label = document.getElementById("novedades-load-more-text")
      if (!grid || !btn) return

      const items = grid.querySelectorAll("[data-load-more-item]")
      if (items.length <= BATCH) {
        btn.parentElement!.remove()
        return
      }

      let shown = BATCH
      items.forEach((el, i) => {
        if (i >= BATCH) el.classList.add("hidden")
      })

      const updateLabel = () => {
        const left = items.length - shown
        if (label) label.textContent = `Cargar más noticias (${left})`
      }
      updateLabel()

      btn.addEventListener("click", () => {
        const next = Math.min(shown + BATCH, items.length)
        for (let i = shown; i < next; i++) items[i].classList.remove("hidden")
        shown = next
        if (shown >= items.length) {
          btn.parentElement!.remove()
          return
        }
        updateLabel()
      })
    })()
  </script>
</Layout>
