---
import { getCollection } from "astro:content";
import Icon from "../components/Icon.astro";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const articulos = await getCollection("articulos", ({ data }) => !data.draft);

const featured = articulos.find((a) => a.data.featured);
const grid = articulos.filter((a) => !a.data.featured);

// Contar artículos por categoría
const categoryCounts = articulos.reduce<Record<string, number>>((acc, a) => {
  acc[a.data.category] = (acc[a.data.category] || 0) + 1;
  return acc;
}, {});
---

<Layout
  title="Novedades"
  description="Novedades y publicaciones — Un espacio para noticias, eventos y análisis del sector energético boliviano."
>
  <Navbar active="novedades" />

  <!-- Header -->
  <header class="py-16 px-8 max-w-7xl mx-auto">
    <h1 class="text-5xl md:text-6xl leading-tight font-bold text-on-surface font-headline tracking-tight max-w-3xl">
      Novedades y publicaciones
    </h1>
    <p class="text-xl text-on-surface-variant mt-6 max-w-2xl leading-relaxed font-body">
      Un espacio para noticias, eventos y análisis del sector energético.
    </p>
  </header>

  <main id="main-content" class="max-w-7xl mx-auto px-8 pb-24 grid grid-cols-1 lg:grid-cols-4 gap-12">
    <!-- Contenido Principal -->
    <div class="lg:col-span-3 space-y-12">
      {
        featured && (
          <!-- Noticia Destacada -->
          <article class="bg-surface-container-low rounded-lg overflow-hidden flex flex-col md:flex-row group transition-all duration-300 hover:bg-surface-container-highest">
            {featured.data.image && (
              <div class="md:w-1/2 min-h-[300px] bg-cover bg-center" style={`background-image: url('${featured.data.image}')`}></div>
            )}
            <div class="p-8 md:w-1/2 flex flex-col justify-center">
              <span class="text-xs font-semibold text-primary uppercase tracking-wider font-label mb-4">
                {featured.data.category}
              </span>
              <h2 class="text-3xl leading-snug font-bold text-on-surface mb-4 font-headline group-hover:text-primary transition-colors">
                {featured.data.title}
              </h2>
              <p class="text-base text-on-surface-variant leading-relaxed font-body mb-6">
                {featured.data.excerpt}
              </p>
              <div class="mt-auto flex items-center justify-between text-sm text-on-surface-variant">
                <span class="flex items-center gap-2">
                  <Icon name="material-symbols:calendar-today" class="size-4" />
                  {featured.data.date}
                </span>
                <a href={`/novedades/${featured.id}`} class="text-primary font-medium hover:underline inline-flex items-center gap-1">
                  Leer más
                  <Icon name="material-symbols:arrow-forward" class="size-4" />
                </a>
              </div>
            </div>
          </article>
        )
      }

      <!-- Grid de Noticias -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {grid.map((articulo) => (
          <article class="bg-surface-container-low p-6 rounded-lg transition-all duration-300 hover:bg-surface-container-highest flex flex-col">
            {articulo.data.image && (
              <div
                class="h-48 rounded bg-cover bg-center mb-6"
                style={`background-image: url('${articulo.data.image}')`}
              ></div>
            )}
            <span class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider font-label mb-3">
              {articulo.data.category}
            </span>
            <h3 class="text-xl font-semibold text-on-surface mb-3 font-headline leading-snug">
              {articulo.data.title}
            </h3>
            <p class="text-base text-on-surface-variant leading-relaxed font-body flex-grow">
              {articulo.data.excerpt}
            </p>
            <div class="mt-6 flex items-center justify-between text-sm text-on-surface-variant border-t border-outline-variant/15 pt-4">
              <span>{articulo.data.date}</span>
            </div>
          </article>
        ))}
      </div>

      <div class="text-center pt-8">
        <button class="bg-surface-container-high text-primary px-6 py-3 rounded-sm text-sm font-medium hover:bg-surface-variant transition-colors font-headline inline-flex items-center gap-2">
          Cargar más noticias
          <Icon name="material-symbols:expand-more" class="size-4" />
        </button>
      </div>
    </div>

    <!-- Sidebar -->
    <aside class="lg:col-span-1 space-y-12">
      <!-- Categorías -->
      <div class="bg-surface-container-low p-6 rounded-lg">
        <h3 class="text-lg font-semibold text-on-surface mb-6 font-headline flex items-center gap-2">
          <Icon name="material-symbols:category" class="text-primary size-5" />
          Categorías
        </h3>
        <ul class="space-y-4">
          {Object.entries(categoryCounts).map(([cat, count]) => (
            <li>
              <a
                href={`/novedades?categoria=${encodeURIComponent(cat)}`}
                class="text-base text-on-surface-variant hover:text-primary transition-colors flex justify-between items-center group font-body"
              >
                {cat}
                <span class="text-xs bg-surface-container-highest px-2 py-1 rounded text-on-surface-variant group-hover:bg-primary-container group-hover:text-on-primary-container transition-colors">
                  {count}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Archivo Histórico -->
      <div class="bg-surface-container-low p-6 rounded-lg">
        <h3 class="text-lg font-semibold text-on-surface mb-6 font-headline flex items-center gap-2">
          <Icon name="material-symbols:history" class="text-primary size-5" />
          Archivo Histórico
        </h3>
        <ul class="space-y-4">
          {["Octubre 2023", "Septiembre 2023", "Agosto 2023", "Julio 2023"].map((month) => (
            <li>
              <a href="#" class="text-base text-on-surface-variant hover:text-primary transition-colors block font-body">
                {month}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="bg-surface-container-lowest border border-outline-variant/15 p-6 rounded-lg shadow-lg">
        <h3 class="text-lg font-semibold text-on-surface mb-2 font-headline">Boletín Informativo</h3>
        <p class="text-sm text-on-surface-variant mb-6 font-body">
          Reciba las últimas novedades directamente en su bandeja de entrada.
        </p>
        <form class="space-y-4" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value={import.meta.env.WEB3FORMS_KEY} />
          <input type="hidden" name="redirect" value={`${Astro.site || ""}/gracias`} />
          <input type="hidden" name="subject" value="Nueva suscripción al boletín — CBHE" />
          <div>
            <label for="newsletter-email" class="block text-sm font-semibold text-on-surface mb-2">Correo electrónico</label>
            <input
              type="email"
              id="newsletter-email"
              name="email"
              autocomplete="email"
              required
              aria-required="true"
              placeholder="Su correo electrónico…"
              class="w-full bg-surface-container-low border-0 border-b-2 border-transparent focus:border-primary focus:ring-0 px-4 py-3 text-sm text-on-surface font-body transition-colors rounded-t-sm"
            />
          </div>
          <button
            type="submit"
            class="w-full bg-primary-container text-on-primary py-3 rounded-sm text-sm font-medium hover:bg-primary hover:text-on-primary transition-colors font-headline disabled:opacity-50"
          >
            Suscribirse
          </button>
        </form>
      </div>
    </aside>
  </main>

  <Footer />
</Layout>
