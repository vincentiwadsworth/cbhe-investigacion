---
import Icon from "../components/Icon.astro";
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Página no encontrada"
  description="La página que busca no existe o ha sido movida."
  noindex={true}
>
  <div class="min-h-[70vh] flex items-center justify-center px-8">
    <div class="text-center max-w-xl">
      <p class="text-8xl font-headline font-extrabold text-primary/20 mb-4">404</p>
      <h1 class="text-3xl sm:text-4xl font-headline font-bold text-on-surface mb-4">
        Página no encontrada
      </h1>
      <p class="text-lg text-on-surface-variant mb-8 leading-relaxed">
        La página que busca no existe o ha sido movida. Verifique la dirección o
        regrese al inicio para explorar nuestro contenido.
      </p>
      <a
        href=""
        class="inline-flex items-center gap-2 bg-primary text-on-primary px-8 py-3 rounded-md font-semibold hover:bg-primary/90 hover:shadow-md transition-all min-h-[44px]"
      >
        <Icon name="material-symbols:arrow-forward" class="size-4 rotate-180" />
        Volver al inicio
      </a>
    </div>
  </div>
</PageLayout>