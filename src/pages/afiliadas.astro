---
import { getCollection } from "astro:content";
import Icon from "../components/Icon.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";

const empresas = await getCollection("empresas", ({ data }) => !data.draft);

const GROUPS = [
  { id: "upstream", label: "Exploración y explotación de hidrocarburos" },
  { id: "pozo", label: "Servicios y suministros especializados en pozo" },
  { id: "superficie", label: "Servicios y suministros especializados en superficie" },
  { id: "downstream", label: "Industria, transporte y distribución de hidrocarburos y energía" },
  { id: "auxiliares", label: "Servicios auxiliares" },
  { id: "adherentes", label: "Adherentes" },
];

const grouped = GROUPS
  .map((group) => ({
    ...group,
    items: empresas
      .filter((e) => e.data.grupo === group.id)
      .sort((a, b) => {
        if (a.data.orden !== b.data.orden) return a.data.orden - b.data.orden;
        return a.data.nombre.localeCompare(b.data.nombre);
      }),
  }))
  .filter((group) => group.items.length > 0);

const totalEmpresas = empresas.length;
---

<Layout
  title="Afiliadas"
  description="Directorio de empresas afiliadas a la CBHE — Más de 50 empresas que integran la cadena de valor del sector hidrocarburífero y energético en Bolivia."
>
  <Navbar active="afiliadas" />

  <main id="main-content">
    <!-- Hero -->
    <section class="relative bg-linear-to-br from-primary to-primary-container pt-20 sm:pt-24 md:pt-28 pb-24 sm:pb-28 md:pb-32 px-4 sm:px-6 md:px-8 overflow-hidden">
      <div class="max-w-7xl mx-auto relative z-10">
        <span class="text-primary-fixed-dim font-bold tracking-widest uppercase text-sm">Directorio</span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-headline font-extrabold text-on-primary leading-tight tracking-tight mt-4">
          Nuestras Afiliadas
        </h1>
        <p class="text-lg sm:text-xl md:text-2xl text-on-primary-container font-body font-medium leading-relaxed mt-4 max-w-3xl">
          {totalEmpresas} empresas que integran la cadena de valor del sector energético boliviano
        </p>
      </div>
    </section>

    <!-- Directory -->
    <section class="py-12 sm:py-16 md:py-24 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        {grouped.map((group) => (
          <details id={`grupo-${group.id}`} open class="scroll-mt-24 mb-4 group/detail border border-surface-container-highest/50 rounded-sm overflow-hidden">
            <summary class="list-none cursor-pointer flex items-center justify-between bg-surface-container-low px-6 py-4 min-h-[44px] hover:bg-surface-container transition-colors">
              <div class="flex items-center gap-3">
                <span class="font-headline font-bold text-on-surface text-base sm:text-lg">{group.label}</span>
                <span class="inline-flex items-center text-xs font-semibold text-on-primary bg-primary-container rounded-sm px-2.5 py-1">{group.items.length} empresas</span>
              </div>
              <Icon name="material-symbols:expand-more" class="size-6 text-on-surface-variant transition-transform duration-200 group-open/detail:rotate-180" />
            </summary>
            <div class="p-4 sm:p-6">
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
                {group.items.map((empresa) => (
                  <article class="bg-surface rounded-sm p-4 sm:p-6 border border-surface-container-highest/50 hover:shadow-md transition-shadow">
                    <h3 class="font-headline font-bold text-on-surface text-base sm:text-lg">{empresa.data.nombre}</h3>
                    <div class="flex flex-wrap gap-3 mt-3">
                      {empresa.data.website && (
                        <a href={empresa.data.website} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm text-primary-container hover:text-primary transition-colors">
                          <Icon name="material-symbols:open-in-new" class="size-4" />
                          Sitio web
                        </a>
                      )}
                      {empresa.data.email && (
                        <a href={`mailto:${empresa.data.email}`} class="inline-flex items-center gap-1 text-sm text-primary-container hover:text-primary transition-colors">
                          <Icon name="material-symbols:mail" class="size-4" />
                          Contacto
                        </a>
                      )}
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
