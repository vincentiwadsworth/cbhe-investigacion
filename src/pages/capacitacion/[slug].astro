---
import { getCollection, render } from "astro:content";
import Icon from "../../components/Icon.astro";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const cursos = await getCollection("cursos", ({ data }) => !data.draft);
  return cursos.map((c) => ({ params: { slug: c.id } }));
}

const { slug } = Astro.params;
const cursos = await getCollection("cursos", ({ data }) => !data.draft);
const curso = cursos.find((c) => c.id === slug);

if (!curso) return Astro.redirect("/404");

const { Content } = await render(curso);

const modeIcons: Record<string, string> = {
  Virtual: "desktop-windows",
  Presencial: "apartment",
  Híbrido: "devices",
};
---

<Layout
  title={curso.data.title}
  description={curso.data.description || `Curso de ${curso.data.category}: ${curso.data.title}`}
  image={curso.data.image}
  currentPath={`capacitacion/${slug}`}
>
  <Navbar active="capacitacion" />

  <main id="main-content" class="max-w-4xl mx-auto px-4 sm:px-6 md:px-8 py-12 sm:py-16 md:py-24">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm text-on-surface-variant" aria-label="Navegación">
      <a href="" class="hover:text-primary hover:underline hover:underline-offset-4 transition-colors">Inicio</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <a href="capacitacion" class="hover:text-primary hover:underline hover:underline-offset-4 transition-colors">Capacitación</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <span class="text-on-surface">{curso.data.title}</span>
    </nav>

    <!-- Hero image -->
    {curso.data.image ? (
      <figure class="mb-10 rounded-xl overflow-hidden">
        <img
          src={curso.data.image}
          alt={curso.data.title}
          class="w-full h-auto object-cover rounded-xl"
          loading="lazy"
        />
      </figure>
    ) : (
      <div class="mb-10 rounded-xl overflow-hidden bg-primary-container aspect-video flex items-center justify-center">
        <Icon name="material-symbols:school" class="size-24 text-primary opacity-30" />
      </div>
    )}

    <!-- Course metadata pills -->
    <div class="flex flex-wrap items-center gap-3 mb-6">
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-primary uppercase tracking-wider bg-primary-container/10 px-3 py-1 rounded-full">
        {curso.data.category}
      </span>
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-on-surface-variant bg-surface-container-high px-3 py-1 rounded-full">
        <Icon name={`material-symbols:${modeIcons[curso.data.modality]}`} class="size-3.5" />
        {curso.data.modality}
      </span>
    </div>

    <!-- Title -->
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-headline font-bold text-on-surface leading-tight tracking-tight mb-8">
      {curso.data.title}
    </h1>

    <!-- Info cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
      <div class="bg-surface-container-low rounded-lg p-5 flex items-start gap-4">
        <Icon name="material-symbols:calendar-today" class="size-6 text-primary shrink-0 mt-0.5" />
        <div>
          <p class="text-sm font-semibold text-on-surface">Fecha de inicio</p>
          <p class="text-on-surface-variant">{curso.data.startDate}</p>
        </div>
      </div>
      {curso.data.price && (
        <div class="bg-surface-container-low rounded-lg p-5 flex items-start gap-4">
          <Icon name="material-symbols:payments" class="size-6 text-primary shrink-0 mt-0.5" />
          <div>
            <p class="text-sm font-semibold text-on-surface">Inversión</p>
            <p class="text-on-surface-variant">{curso.data.price}</p>
          </div>
        </div>
      )}
      {curso.data.registrationDeadline && (
        <div class="bg-surface-container-low rounded-lg p-5 flex items-start gap-4">
          <Icon name="material-symbols:calendar-today" class="size-6 text-primary shrink-0 mt-0.5" />
          <div>
            <p class="text-sm font-semibold text-on-surface">Fecha límite inscripción</p>
            <p class="text-on-surface-variant">{curso.data.registrationDeadline}</p>
          </div>
        </div>
      )}
    </div>

    <!-- Description -->
    {curso.data.description && (
      <div class="mb-10 bg-surface-container-low rounded-lg p-6 border-l-4 border-primary">
        <p class="text-on-surface-variant leading-relaxed">{curso.data.description}</p>
      </div>
    )}

    <!-- Canva link CTA -->
    {curso.data.canvaLink && (
      <div class="mb-10 bg-primary-container/10 rounded-lg p-6 flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="flex-1">
          <p class="text-sm font-semibold text-on-surface">Arte completo del curso</p>
          <p class="text-sm text-on-surface-variant">Toda la información detallada, agenda y requisitos en el diseño oficial.</p>
        </div>
        <a
          href={curso.data.canvaLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary text-on-primary px-6 py-3 rounded-md font-semibold hover:bg-primary/90 hover:shadow-md transition-all min-h-[44px] whitespace-nowrap"
        >
          <Icon name="material-symbols:palette" class="size-5" />
          Ver en Canva
        </a>
      </div>
    )}

    <!-- Instructors -->
    {curso.data.instructors && curso.data.instructors.length > 0 && (
      <div class="mb-10">
        <h2 class="text-2xl font-headline font-bold text-on-surface mb-6">Ponentes</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {curso.data.instructors.map((instructor) => (
            <div class="bg-surface-container-low rounded-lg p-6">
              <h3 class="text-lg font-headline font-bold text-on-surface mb-2">{instructor.name}</h3>
              {instructor.bio && (
                <p class="text-sm text-on-surface-variant leading-relaxed">{instructor.bio}</p>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Course body -->
    <article class="prose prose-lg max-w-none
      prose-headings:font-headline prose-headings:text-on-surface prose-headings:font-bold
      prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
      prose-p:text-on-surface-variant prose-p:leading-relaxed prose-p:mb-5
      prose-a:text-primary prose-a:no-underline hover:prose-a:underline
      prose-strong:text-on-surface prose-strong:font-semibold
      prose-ul:text-on-surface-variant prose-li:marker:text-primary
    ">
      <Content />
    </article>

    <!-- CTA -->
    <div class="mt-16 bg-primary-container/10 rounded-lg p-8 text-center">
      <h2 class="text-2xl font-headline font-bold text-on-surface mb-4">¿Interesado en este curso?</h2>
      <p class="text-on-surface-variant mb-6">Contáctenos por WhatsApp para más información sobre inscripciones y descuentos.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        {curso.data.canvaLink && (
          <a
            href={curso.data.canvaLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-surface-container-high text-primary px-8 py-4 rounded-md font-semibold hover:bg-surface-container hover:border-primary/30 transition-all min-h-[44px]"
          >
            <Icon name="material-symbols:palette" class="size-5" />
            Ver arte completo en Canva
          </a>
        )}
        <a
          href="https://wa.me/59178500177"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary text-on-primary px-8 py-4 rounded-md font-semibold hover:bg-primary/90 hover:shadow-md transition-all min-h-[44px]"
        >
          <Icon name="material-symbols:chat" class="size-5" />
          Consultar por WhatsApp
        </a>
      </div>
    </div>

    <!-- Back link -->
    <div class="mt-12 pt-8 border-t border-outline-variant/30">
      <a href="capacitacion" class="inline-flex items-center gap-2 text-primary font-medium hover:underline hover:underline-offset-4">
        <Icon name="material-symbols:arrow-forward" class="size-4 rotate-180" />
        Volver a capacitación
      </a>
    </div>
  </main>

  <Footer />
</Layout>
