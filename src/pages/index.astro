---
import { getCollection } from "astro:content";
import Icon from "../components/Icon.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Layout from "../layouts/Layout.astro";
import PreciosGrid from "../components/PreciosGrid.astro";
import preciosData from "../../data/prices.json";

const articulos = await getCollection("articulos", ({ data }) => !data.draft);
const cursos = await getCollection("cursos", ({ data }) => !data.draft);

const MESES: Record<string, number> = { Ene:0, Feb:1, Mar:2, Abr:3, May:4, Jun:5, Jul:6, Ago:7, Sep:8, Oct:9, Nov:10, Dic:11 };
const parseFecha = (d: string) => {
  const limpio = d.replace(/^Inicia:\s*/i, "").trim();
  const [dia, mes, año] = limpio.split(" ");
  return new Date(+año, MESES[mes], +dia).getTime();
};

const articulosPorFecha = (a: any, b: any) => parseFecha(b.data.date) - parseFecha(a.data.date);
const cursosPorFecha = (a: any, b: any) => parseFecha(b.data.startDate) - parseFecha(a.data.startDate);

const ultimosArticulos = articulos.sort(articulosPorFecha).slice(0, 3);
const cursosDestacados = cursos.sort(cursosPorFecha).slice(0, 2);

const modeIcons: Record<string, string> = {
  Virtual: "desktop-windows",
  Presencial: "apartment",
  Híbrido: "devices",
};
---

<Layout
  title="Inicio"
  description="Cámara Boliviana de Hidrocarburos y Energía — Integramos energías con liderazgo e innovación."
>
  <Navbar active="inicio" />

  <main id="main-content">
    <!-- Hero -->
    <header class="relative min-h-[85dvh] sm:min-h-[550px] md:min-h-[600px] flex items-center sm:items-end bg-surface-container-low overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img
          alt="Vista aérea de gasoducto cruzando el paisaje boliviano entre el Chaco y la Amazonía al atardecer"
          class="w-full h-full object-cover"
          data-hero-image
          fetchpriority="high"
          height="800"
          src="hero-inicio.webp"
          width="1200"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 md:px-8 w-full pb-10 sm:pb-12 md:pb-16 text-center">
        <h1 class="text-white font-headline font-extrabold text-3xl sm:text-4xl md:text-5xl lg:text-6xl leading-tight mb-5 md:mb-6 tracking-tight max-w-4xl mx-auto">
          <span class="block">OPERAMOS EL <span class="text-primary-fixed text-5xl sm:text-6xl md:text-7xl lg:text-8xl">99%</span></span>
          <span class="block">DE LA PRODUCCIÓN DE GAS</span>
          <span class="block">NATURAL NACIONAL</span>
        </h1>
        <p class="text-white/80 font-body text-base sm:text-lg md:text-xl mb-8 sm:mb-10 md:mb-12 max-w-2xl mx-auto leading-relaxed">
          Integramos energías con liderazgo e innovación desde 1986.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="quienes-somos" class="bg-surface text-primary rounded-sm px-6 sm:px-8 py-3.5 sm:py-4 font-semibold hover:bg-surface-container-highest transition-colors">
            Conózcanos
          </a>
          <a href="novedades" class="border-2 border-white/60 text-white rounded-sm px-6 sm:px-8 py-3.5 sm:py-4 font-semibold hover:bg-white/10 transition-colors">
            Novedades
          </a>
        </div>
      </div>
    </header>

    <!-- Datos del Sector -->
    <PreciosGrid data={preciosData} />

    <!-- Quiénes Somos (Resumen) -->
    <section class="py-12 sm:py-16 md:py-24 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 items-center">
          <div>
            <h2 class="text-primary font-headline text-2xl md:text-3xl font-bold mb-6">Impulsamos el desarrollo del sector</h2>
            <p class="text-on-surface-variant font-body text-base md:text-lg leading-relaxed mb-6">
              La Cámara Boliviana de Hidrocarburos y Energía (CBHE) agrupa a las principales empresas que operan en la cadena productiva del sector hidrocarburífero y energético del país. Nuestro propósito es ser el eje articulador de la industria.
            </p>
            <p class="text-on-surface-variant font-body text-base md:text-lg leading-relaxed mb-8">
              Nuestra labor está enfocada en la coordinación técnica, el análisis normativo, la promoción de mejores prácticas y el fomento de la capacitación de excelencia, garantizando el desarrollo responsable de los recursos energéticos.
            </p>
            <a href="quienes-somos" class="inline-flex items-center text-primary-container font-semibold hover:underline decoration-primary-container underline-offset-4">
              Conozca nuestra misión
              <Icon name="material-symbols:arrow-forward" class="size-4 ml-2" />
            </a>
          </div>

          <div class="relative h-[400px] rounded-sm overflow-hidden bg-surface-container-low shadow-sm">
            <img
              alt="Instalaciones de la CBHE con torre de estructuras metálicas bajo cielo azul"
              class="w-full h-full object-cover"
              src="images/cbhe-exterior.webp"
            />
            <div class="absolute bottom-0 left-0 right-0 bg-surface/90 backdrop-blur-sm p-6 border-t border-surface-container-highest">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-primary font-bold text-2xl">40</p>
                  <p class="text-on-surface-variant text-sm font-medium">Años de trayectoria</p>
                </div>
                <div class="w-px h-12 bg-surface-container-highest"></div>
                <div>
                  <p class="text-primary font-bold text-2xl">+50</p>
                  <p class="text-on-surface-variant text-sm font-medium">Empresas afiliadas</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Grupos de Miembros -->
    <section class="py-12 sm:py-16 md:py-24 bg-surface-container-low">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <div class="mb-10 md:mb-16">
          <h2 class="text-primary font-headline text-2xl md:text-3xl font-bold mb-4">Nuestras afiliadas</h2>
          <p class="text-on-surface-variant font-body text-base md:text-lg max-w-3xl">
            Representamos a las empresas que integran la cadena de valor de la industria energética, organizadas en cinco grupos especializados con el objetivo de lograr una coordinación eficiente.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
          {
            [
              { icon: "explore", title: "Exploración y producción", desc: "Empresas dedicadas a la búsqueda y extracción de recursos hidrocarburíferos." },
              { icon: "engineering", title: "Servicios en pozo", desc: "Perforación, terminación y mantenimiento especializado de pozos." },
              { icon: "factory", title: "Servicios en superficie", desc: "Construcción, ingeniería y operación de facilidades de producción." },
              { icon: "local-shipping", title: "Industria y transporte", desc: "Refinación, comercialización, ductos y logística especializada." },
              { icon: "handyman", title: "Servicios auxiliares", desc: "Consultoría, tecnología, provisión de equipos y servicios transversales." },
            ].map((group) => (
              <article class="bg-surface rounded-sm p-6 hover:bg-surface-container-highest transition-colors duration-300 group cursor-pointer border border-surface-container-highest/50">
                <div class="w-12 h-12 bg-surface-container-low rounded-sm flex items-center justify-center mb-6 group-hover:bg-primary-container transition-colors">
                  <Icon name={`material-symbols:${group.icon}`} class="text-primary size-6 group-hover:text-on-primary" />
                </div>
                <h3 class="font-headline font-bold text-on-surface mb-2">{group.title}</h3>
                <p class="text-on-surface-variant text-sm leading-relaxed">{group.desc}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Formulario de Afiliación -->
    <section id="afiliacion" class="scroll-mt-24 py-12 sm:py-16 md:py-24 bg-[#01406c]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 items-center">
          <div>
            <h2 class="text-white font-headline text-2xl md:text-3xl font-bold mb-4">Afilie a su empresa</h2>
              <p class="text-white/80 font-body text-base md:text-lg mb-6">
              Únase a la red más importante de empresas del sector energético en Bolivia. Complete el formulario y nuestro equipo de afiliaciones se pondrá en contacto con su empresa a la brevedad.
            </p>
            <a
              href="afiliacion"
              class="inline-flex items-center gap-2 text-primary-fixed font-semibold hover:underline decoration-primary-fixed underline-offset-4 mb-8"
            >
              <Icon name="material-symbols:fact-check" class="size-5" />
              Ver requisitos de afiliación
              <Icon name="material-symbols:arrow-forward" class="size-4" />
            </a>
            <div class="space-y-4">
              <div class="flex items-start gap-4">
                <Icon name="material-symbols:check-circle" class="text-primary-fixed size-6 mt-0.5 shrink-0" />
                <div>
                  <h4 class="font-bold text-white">Representación sectorial</h4>
                  <p class="text-sm text-white/70">Voz activa en la defensa y promoción del sector ante instancias gubernamentales.</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <Icon name="material-symbols:check-circle" class="text-primary-fixed size-6 mt-0.5 shrink-0" />
                <div>
                  <h4 class="font-bold text-white">Actualización técnica</h4>
                  <p class="text-sm text-white/70">Acceso exclusivo a estadísticas, normativas y capacitaciones de alto nivel.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-surface-container-low p-8 rounded-sm shadow-sm border border-surface-container-highest">
            <form class="space-y-6" action="https://api.web3forms.com/submit" method="POST">
              <input type="hidden" name="access_key" value={import.meta.env.WEB3FORMS_KEY} />
              <input type="hidden" name="redirect" value={new URL(`${import.meta.env.BASE_URL}/gracias`, Astro.site).href} />
              <input type="hidden" name="subject" value="Nueva solicitud de afiliación — CBHE" />
              <input type="hidden" name="from_name" value="Formulario de Afiliación CBHE" />
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-semibold text-on-surface mb-2" for="company">Nombre de la Empresa <span class="text-error" aria-hidden="true">*</span></label>
                  <input class="w-full bg-surface border border-surface-container-highest rounded-sm focus:border-primary-container focus:ring-primary-container px-4 py-2.5 text-on-surface" id="company" name="company" type="text" autocomplete="organization" placeholder="Ej. Energía S.A.…" required aria-required="true" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-on-surface mb-2" for="sector">Sector de la Industria <span class="text-error" aria-hidden="true">*</span></label>
                  <select class="w-full bg-surface border border-surface-container-highest rounded-sm focus:border-primary-container focus:ring-primary-container px-4 py-2.5 text-on-surface" id="sector" name="sector" required aria-required="true">
                    <option value="">Seleccione un sector</option>
                    <option value="exploracion">Exploración y Producción</option>
                    <option value="servicios-pozo">Servicios en Pozo</option>
                    <option value="servicios-superficie">Servicios en Superficie</option>
                    <option value="transporte">Industria y Transporte</option>
                    <option value="auxiliares">Servicios Auxiliares</option>
                  </select>
                </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-semibold text-on-surface mb-2" for="contact">Persona de Contacto <span class="text-error" aria-hidden="true">*</span></label>
                  <input class="w-full bg-surface border border-surface-container-highest rounded-sm focus:border-primary-container focus:ring-primary-container px-4 py-2.5 text-on-surface" id="contact" name="contact" type="text" autocomplete="name" placeholder="Nombre completo…" required aria-required="true" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-on-surface mb-2" for="email">Correo Electrónico <span class="text-error" aria-hidden="true">*</span></label>
                  <input class="w-full bg-surface border border-surface-container-highest rounded-sm focus:border-primary-container focus:ring-primary-container px-4 py-2.5 text-on-surface" id="email" name="email" type="email" autocomplete="email" placeholder="email@empresa.com…" required aria-required="true" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-semibold text-on-surface mb-2" for="message">Mensaje / Comentarios</label>
                <textarea class="w-full bg-surface border border-surface-container-highest rounded-sm focus:border-primary-container focus:ring-primary-container px-4 py-2.5 text-on-surface" id="message" name="message" rows="4" placeholder="Indíquenos el motivo de su interés…"></textarea>
              </div>
              <button class="w-full bg-primary-container text-on-primary rounded-sm py-4 font-bold hover:opacity-90 transition-opacity disabled:opacity-50 flex items-center justify-center gap-2" type="submit">
                Enviar Solicitud
                <Icon name="material-symbols:send" class="size-5" />
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- Últimas Novedades -->
    <section class="py-12 sm:py-16 md:py-24 bg-surface">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <div class="mb-8 md:mb-12">
          <h2 class="text-primary font-headline text-2xl md:text-3xl font-bold mb-4">Novedades</h2>
          <p class="text-on-surface-variant font-body text-base md:text-lg max-w-3xl">
            Manténgase al día con las últimas noticias, eventos y análisis del sector energético boliviano.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {ultimosArticulos.map((articulo) => (
            <article class="bg-surface-container-low rounded-sm overflow-hidden border border-surface-container-highest/50 shadow-sm hover:shadow-md transition-shadow group">
              {articulo.data.image && (
                <div class="h-48 overflow-hidden">
                  <img
                    alt={articulo.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    src={articulo.data.image}
                  />
                </div>
              )}
              <div class="p-6 flex flex-col items-start">
                <span class="text-xs font-semibold text-primary-container mb-2 tracking-wide uppercase">{articulo.data.category}</span>
                <h3 class="font-headline font-bold text-xl text-on-surface mb-3 line-clamp-2">{articulo.data.title}</h3>
                <p class="text-sm text-on-surface-variant mb-4 line-clamp-3">{articulo.data.excerpt}</p>
                <div class="mt-auto flex items-center justify-between w-full">
                  <span class="text-xs text-on-surface-variant">{articulo.data.date}</span>
                  <a href={`novedades/${articulo.id}`} class="text-sm font-semibold text-primary hover:text-primary-container transition-colors">Leer más</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Cursos Destacados -->
    <section class="py-12 sm:py-16 md:py-24 bg-surface-container-low">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
        <div class="mb-8 md:mb-12">
          <h2 class="text-primary font-headline text-2xl md:text-3xl font-bold mb-4">CBHE Capacitación</h2>
          <p class="text-on-surface-variant font-body text-base md:text-lg max-w-3xl">Conozca nuestros cursos y programas de formación técnica.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          {cursosDestacados.map((curso) => (
            <article class="bg-surface rounded-sm overflow-hidden flex flex-col sm:flex-row border border-surface-container-highest/50 shadow-sm hover:shadow-md transition-shadow group cursor-pointer">
              <div class="w-full sm:w-2/5 h-48 sm:h-auto overflow-hidden">
                {curso.data.image ? (
                  <img
                    alt={curso.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    src={curso.data.image}
                  />
                ) : (
                  <div class="w-full h-full bg-primary-container flex items-center justify-center">
                    <Icon name="material-symbols:school" class="size-12 text-primary opacity-30" />
                  </div>
                )}
              </div>
              <div class="p-6 flex flex-col justify-center w-full sm:w-3/5">
                <h3 class="font-headline font-bold text-xl text-on-surface mb-2">{curso.data.title}</h3>
                <p class="text-sm text-on-surface-variant mb-4 line-clamp-3">{curso.data.description}</p>
                {curso.data.canvaLink ? (
                  <a href={curso.data.canvaLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-primary-container font-semibold hover:text-primary transition-colors mt-auto">
                    Ver más
                    <Icon name="material-symbols:open-in-new" class="size-4 ml-2" />
                  </a>
                ) : (
                  <a href={`capacitacion/${curso.id}`} class="inline-flex items-center text-primary-container font-semibold hover:text-primary transition-colors mt-auto">
                    Más información
                    <Icon name="material-symbols:arrow-forward" class="size-4 ml-2" />
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
