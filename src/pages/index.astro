---
import { getCollection } from "astro:content";
import Icon from "../components/Icon.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Web3Form from "../components/Web3Form.astro";
import FormInput from "../components/FormInput.astro";
import CtaBanner from "../components/CtaBanner.astro";
import PageLayout from "../layouts/PageLayout.astro";
import PreciosGrid from "../components/PreciosGrid.astro";
import preciosData from "../../data/prices.json";

const articulos = await getCollection("articulos", ({ data }) => !data.draft);
const cursos = await getCollection("cursos", ({ data }) => !data.draft);
const empresas = await getCollection("empresas");

const MESES: Record<string, number> = { Ene:0, Feb:1, Mar:2, Abr:3, May:4, Jun:5, Jul:6, Ago:7, Sep:8, Oct:9, Nov:10, Dic:11 };
const parseFecha = (d: string) => {
  const limpio = d.replace(/^Inicia:\s*/i, "").trim();
  const [dia, mes, año] = limpio.split(" ");
  return new Date(+año, MESES[mes], +dia).getTime();
};

const articulosPorFecha = (a: any, b: any) => parseFecha(b.data.date) - parseFecha(a.data.date);
const cursosPorFecha = (a: any, b: any) => parseFecha(b.data.startDate) - parseFecha(a.data.startDate);

const ultimosArticulos = articulos.sort(articulosPorFecha).slice(0, 3);
const cursosDestacados = cursos.sort(cursosPorFecha).slice(0, 2);

const modeIcons: Record<string, string> = {
  Virtual: "desktop-windows",
  Presencial: "apartment",
  Híbrido: "devices",
};

const groupSlugs: Record<string, string> = {
  "Exploración y producción": "upstream",
  "Servicios en pozo": "pozo",
  "Servicios en superficie": "superficie",
  "Industria y transporte": "downstream",
  "Servicios auxiliares": "auxiliares",
};

const countByGroup: Record<string, number> = {
  upstream: empresas.filter((e) => e.data.grupo === "upstream").length,
  pozo: empresas.filter((e) => e.data.grupo === "pozo").length,
  superficie: empresas.filter((e) => e.data.grupo === "superficie").length,
  downstream: empresas.filter((e) => e.data.grupo === "downstream").length,
  auxiliares: empresas.filter((e) => e.data.grupo === "auxiliares").length,
};

const gruposHome = [
  { title: "Exploración y producción", desc: "Búsqueda y extracción de hidrocarburos con tecnología de vanguardia.", count: countByGroup.upstream },
  { title: "Servicios en pozo", desc: "Perforación, terminación, cementación y mantenimiento de pozos.", count: countByGroup.pozo },
  { title: "Servicios en superficie", desc: "Ingeniería, construcción y operación de facilidades de producción.", count: countByGroup.superficie },
  { title: "Industria y transporte", desc: "Refinación, ductos, distribución y comercialización de hidrocarburos y energía.", count: countByGroup.downstream },
  { title: "Servicios auxiliares", desc: "Consultoría legal, técnica, ambiental, seguros y logística.", count: countByGroup.auxiliares },
];
---

<PageLayout title="Inicio" description="Cámara Boliviana de Hidrocarburos y Energía — Integramos energías con liderazgo e innovación." active="inicio">
  <!-- Homepage Hero (unique — not a SubpageHero) -->
  <header class="relative min-h-[85dvh] sm:min-h-[550px] md:min-h-[600px] flex items-center sm:items-end bg-surface-container-low overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        alt="Vista aérea de gasoducto cruzando el paisaje boliviano entre el Chaco y la Amazonía al atardecer"
        class="w-full h-full object-cover"
        data-hero-image
        fetchpriority="high"
        height="800"
        src="hero-inicio.webp"
        width="1200"
      />
      <div class="absolute inset-0 bg-black/70"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 md:px-8 w-full pb-10 sm:pb-12 md:pb-16 text-center">
      <h1 class="text-inverse-on-surface font-headline font-extrabold text-3xl sm:text-4xl md:text-5xl lg:text-6xl leading-tight mb-5 md:mb-6 tracking-tight max-w-4xl mx-auto">
        <span class="block">Participamos en la producción del</span>
        <span class="block"><span class="text-primary-fixed text-5xl sm:text-6xl md:text-7xl lg:text-8xl">99%</span></span>
        <span class="block">del gas natural boliviano</span>
      </h1>
      <p class="text-inverse-on-surface/80 font-body text-base sm:text-lg md:text-xl mb-8 sm:mb-10 md:mb-12 max-w-2xl mx-auto leading-relaxed">
        Integramos energías con liderazgo e innovación desde 1986.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="quienes-somos" class="bg-inverse-on-surface text-inverse-surface rounded-md px-6 sm:px-8 py-3.5 sm:py-4 font-semibold hover:bg-surface-bright hover:shadow-md transition-all min-h-[44px]">
          Conocernos
        </a>
        <a href="novedades" class="border-2 border-inverse-on-surface/40 text-inverse-on-surface rounded-md px-6 sm:px-8 py-3.5 sm:py-4 font-semibold hover:bg-inverse-on-surface/10 transition-all min-h-[44px]">
          Novedades
        </a>
      </div>
    </div>
  </header>

  <!-- Datos del Sector -->
  <PreciosGrid data={preciosData} />

  <!-- Quiénes Somos (Resumen) -->
  <Section bg="surface">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 items-center">
      <div>
        <SectionHeading title="Impulsamos el desarrollo del sector">
          <Fragment slot="description">
            <p class="text-on-surface-variant font-body text-base md:text-lg leading-relaxed mb-6">
              La Cámara Boliviana de Hidrocarburos y Energía (CBHE) agrupa a las principales empresas que operan en la cadena productiva del sector hidrocarburífero y energético del país. Nuestro propósito es ser el eje articulador de la industria.
            </p>
            <p class="text-on-surface-variant font-body text-base md:text-lg leading-relaxed mb-8">
              Nuestra labor está enfocada en la coordinación técnica, el análisis normativo, la promoción de mejores prácticas y el fomento de la capacitación de excelencia, garantizando el desarrollo responsable de los recursos energéticos.
            </p>
          </Fragment>
        </SectionHeading>
        <a href="quienes-somos" class="inline-flex items-center text-primary-container font-semibold hover:underline hover:underline-offset-4 decoration-primary-container transition-colors">
          Conocer nuestra misión
          <Icon name="material-symbols:arrow-forward" class="size-4 ml-2" />
        </a>
      </div>

      <div class="relative h-[400px] rounded-xl overflow-hidden bg-surface-container-low shadow-sm">
        <img
          alt="Instalaciones de la CBHE con torre de estructuras metálicas bajo cielo azul"
          class="w-full h-full object-cover object-bottom brightness-90 contrast-125"
          src="images/cbhe-exterior.webp"
        />
        <div class="absolute bottom-0 left-0 right-0 bg-surface/90 backdrop-blur-sm p-6 border-t border-outline-variant/30">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-primary font-bold text-2xl">40</p>
              <p class="text-on-surface-variant text-sm font-medium">Años de trayectoria</p>
            </div>
            <div class="w-px h-12 bg-surface-container-highest"></div>
            <div>
              <p class="text-primary font-bold text-2xl">{empresas.length}</p>
              <p class="text-on-surface-variant text-sm font-medium">Empresas afiliadas</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Grupos de Miembros -->
  <Section bg="surface-container-low">
    <SectionHeading title="Nuestras afiliadas" description="Representamos a las empresas que integran la cadena de valor de la industria energética, organizadas en cinco grupos especializados con el objetivo de lograr una coordinación eficiente." />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {gruposHome.map((group) => (
        <a href={`afiliadas#grupo-${groupSlugs[group.title]}`} class="block group">
          <article class="bg-surface rounded-lg border-t-4 border-primary-container hover:border-primary/30 hover:shadow-md hover:scale-[1.01] transition-all duration-300 h-full">
            <div class="p-6 md:p-8">
              <p class="font-headline font-extrabold text-4xl md:text-5xl text-primary mb-2 tracking-tight">{group.count}</p>
              <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-3">empresas</p>
              <h3 class="font-headline font-bold text-on-surface text-lg mb-3 group-hover:text-primary transition-colors">{group.title}</h3>
              <p class="text-on-surface-variant text-sm leading-relaxed">{group.desc}</p>
            </div>
          </article>
        </a>
      ))}
    </div>
  </Section>

  <!-- Alianzas Estratégicas -->
  <Section bg="surface">
    <SectionHeading title="Alianzas estratégicas" description="Colaboramos con instituciones y organizaciones líderes del sector energético a nivel internacional." align="center" maxW="max-w-2xl" />
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
      <a href="https://www.aws.org/" target="_blank" rel="noopener noreferrer" aria-label="American Welding Society (AWS)">
        <img src="/cbhe-web/images/alianzas/aws.webp" alt="AWS — American Welding Society" class="h-10 md:h-12 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300" loading="lazy" />
      </a>
      <a href="https://www.arpel.org/" target="_blank" rel="noopener noreferrer" aria-label="ARPEL">
        <img src="/cbhe-web/images/alianzas/arpel.webp" alt="ARPEL — Asociación de Empresas de Petróleo, Gas y Energía Renovable" class="h-10 md:h-12 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300" loading="lazy" />
      </a>
      <a href="https://iccwbo.org/" target="_blank" rel="noopener noreferrer" aria-label="ICC — International Chamber of Commerce">
        <img src="/cbhe-web/images/alianzas/icc.webp" alt="ICC — International Chamber of Commerce" class="h-10 md:h-12 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300" loading="lazy" />
      </a>
      <a href="https://enginzone.pe/" target="_blank" rel="noopener noreferrer" aria-label="EnginZone">
        <img src="/cbhe-web/images/images/alianzas/enginzone.webp" alt="EnginZone — Capacitación técnica NFPA" class="h-10 md:h-12 w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300" loading="lazy" />
      </a>
    </div>
  </Section>

  <!-- Formulario de Afiliación -->
  <Section id="afiliacion" bg="inverse-surface" scrollMargin>
    <CtaBanner
      title="Afilie a su empresa"
      description="Únase a la red más importante de empresas del sector energético en Bolivia. Complete el formulario y nuestro equipo de afiliaciones se pondrá en contacto con su empresa a la brevedad."
      variant="dark"
      maxWidth="max-w-7xl"
      py="py-0"
    >
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 items-start mt-8">
        <div>
          <a
            href="afiliacion"
            class="inline-flex items-center gap-2 text-primary-fixed font-semibold hover:underline hover:underline-offset-4 decoration-primary-fixed transition-colors mb-8"
          >
            <Icon name="material-symbols:fact-check" class="size-5" />
            Ver requisitos de afiliación
            <Icon name="material-symbols:arrow-forward" class="size-4" />
          </a>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <Icon name="material-symbols:check-circle" class="text-primary-fixed size-6 mt-0.5 shrink-0" />
              <div>
                <h4 class="font-bold text-inverse-on-surface">Representación sectorial</h4>
                <p class="text-sm text-inverse-on-surface/70">Voz activa en la defensa y promoción del sector ante instancias gubernamentales.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <Icon name="material-symbols:check-circle" class="text-primary-fixed size-6 mt-0.5 shrink-0" />
              <div>
                <h4 class="font-bold text-inverse-on-surface">Actualización técnica</h4>
                <p class="text-sm text-inverse-on-surface/70">Acceso exclusivo a estadísticas, normativas y capacitaciones de alto nivel.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-surface-bright p-8 rounded-lg shadow-md border border-outline-variant/30">
          <!-- Using separate icon import from CtaBanner context — the form lives inside the slot -->
          <Web3Form subject="Nueva solicitud de afiliación — CBHE" fromName="Formulario de Afiliación CBHE">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <FormInput id="company" label="Nombre de la Empresa" required autocomplete="organization" placeholder="Ej. Energía S.A.…" />
              <FormInput id="sector" label="Sector de la Industria" type="select" required options={[
                { value: "", label: "Seleccione un sector" },
                { value: "exploracion", label: "Exploración y Producción" },
                { value: "servicios-pozo", label: "Servicios en Pozo" },
                { value: "servicios-superficie", label: "Servicios en Superficie" },
                { value: "transporte", label: "Industria y Transporte" },
                { value: "auxiliares", label: "Servicios Auxiliares" },
              ]} />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <FormInput id="contact" label="Persona de Contacto" required autocomplete="name" placeholder="Nombre completo…" />
              <FormInput id="email" label="Correo Electrónico" type="email" required autocomplete="email" placeholder="email@empresa.com…" />
            </div>
            <FormInput id="message" label="Mensaje / Comentarios" type="textarea" rows={4} placeholder="Indíquenos el motivo de su interés…" />
            <button class="w-full bg-primary text-on-primary rounded-md py-4 font-bold hover:bg-primary/90 hover:shadow-md transition-all min-h-[44px] disabled:opacity-50 flex items-center justify-center gap-2" type="submit">
              Enviar solicitud
              <Icon name="material-symbols:send" class="size-5" />
            </button>
          </Web3Form>
        </div>
      </div>
    </CtaBanner>
  </Section>

  <!-- Últimas Novedades -->
  <Section bg="surface">
    <SectionHeading title="Novedades" description="Manténgase al día con las últimas noticias, eventos y análisis del sector energético boliviano." />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {ultimosArticulos.map((articulo) => (
        <article class="bg-surface-container-low rounded-lg overflow-hidden border border-outline-variant/30 shadow-sm hover:shadow-md hover:border-primary/30 transition-all duration-300 group">
          {articulo.data.image && (
            <div class="h-48 overflow-hidden">
              <img
                alt={articulo.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                src={articulo.data.image}
              />
            </div>
          )}
          <div class="p-6 flex flex-col items-start">
            <span class="text-xs font-semibold text-primary-container mb-2 tracking-wide uppercase">{articulo.data.category}</span>
            <h3 class="font-headline font-bold text-xl text-on-surface mb-3 line-clamp-2">{articulo.data.title}</h3>
            <p class="text-sm text-on-surface-variant mb-4 line-clamp-3">{articulo.data.excerpt}</p>
            <div class="mt-auto flex items-center justify-between w-full">
              <span class="text-xs text-on-surface-variant">{articulo.data.date}</span>
              <a href={`novedades/${articulo.id}`} class="text-sm font-semibold text-primary hover:text-primary-container transition-colors">Leer más</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <!-- Cursos Destacados -->
  <Section bg="surface-container-low">
    <SectionHeading title="CBHE Capacitación" description="Conozca nuestros cursos y programas de formación técnica." />
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {cursosDestacados.map((curso) => (
        <article class="bg-surface rounded-lg overflow-hidden flex flex-col sm:flex-row border border-outline-variant/30 shadow-sm hover:shadow-md transition-shadow group cursor-pointer">
          <div class="w-full sm:w-2/5 h-48 sm:h-auto overflow-hidden">
            {curso.data.image ? (
              <img
                alt={curso.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                src={curso.data.image}
              />
            ) : (
              <div class="w-full h-full bg-primary-container flex items-center justify-center">
                <Icon name="material-symbols:school" class="size-12 text-primary opacity-30" />
              </div>
            )}
          </div>
          <div class="p-6 flex flex-col justify-center w-full sm:w-3/5">
            <h3 class="font-headline font-bold text-xl text-on-surface mb-2">{curso.data.title}</h3>
            <p class="text-sm text-on-surface-variant mb-4 line-clamp-3">{curso.data.description}</p>
            {curso.data.canvaLink ? (
              <a href={curso.data.canvaLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-primary-container font-semibold hover:text-primary hover:underline hover:underline-offset-4 transition-colors mt-auto">
                Ver más
                <Icon name="material-symbols:open-in-new" class="size-4 ml-2" />
              </a>
            ) : (
              <a href={`capacitacion/${curso.id}`} class="inline-flex items-center text-primary-container font-semibold hover:text-primary hover:underline hover:underline-offset-4 transition-colors mt-auto">
                Más información
                <Icon name="material-symbols:arrow-forward" class="size-4 ml-2" />
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </Section>
</PageLayout>